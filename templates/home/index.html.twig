{% extends 'base.html.twig' %}
{% block title %}BeautyAffair · Salon de beauté & Boutique{% endblock %}

{% block stylesheets %}
<style>
/* ─── HERO ─── */
.hero {
    min-height: 88vh;
    display: flex; align-items: center;
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 50%, var(--brown) 100%);
}
/* Vidéo d'arrière-plan */
.hero-video {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%; min-height: 100%;
    width: auto; height: auto;
    object-fit: cover;
    z-index: 0;
    opacity: 0;
    transition: opacity 1s ease;
}
.hero-video.loaded { opacity: 1; }
/* Overlay sombre pour garder le texte lisible */
.hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
        135deg,
        rgba(30,10,2,.78) 0%,
        rgba(61,26,8,.65) 50%,
        rgba(30,10,2,.55) 100%
    );
    z-index: 1;
}
.hero::before {
    content: '';
    position: absolute; inset: 0; z-index: 2;
    background: radial-gradient(ellipse at 70% 50%, rgba(212,192,165,.08) 0%, transparent 65%);
}
.hero-content {
    position: relative; z-index: 3;
    max-width: 1200px; margin: 0 auto;
    padding: 80px 24px;
}
.hero-eyebrow {
    display: inline-block;
    font-size: .7rem; font-weight: 500;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--beige); margin-bottom: 24px;
}
.hero h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 300; line-height: 1.05;
    margin-bottom: 24px;
    max-width: 14ch;
    color: var(--cream);
}
.hero h1 em {
    font-style: italic; color: var(--gold-light);
}
.hero p {
    font-size: 1.1rem; max-width: 44ch;
    margin-bottom: 40px; color: var(--beige);
    line-height: 1.8;
}
.hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
.hero-actions .btn {
    background: var(--cream);
    color: var(--brown-dark);
    border-color: var(--cream);
}
.hero-actions .btn:hover {
    background: var(--beige);
    border-color: var(--beige);
}
.hero-actions .btn-outline {
    color: var(--cream);
    border-color: rgba(253,248,243,.5);
}
.hero-actions .btn-outline:hover {
    background: rgba(253,248,243,.1);
    border-color: var(--cream);
}
.hero-badge {
    position: absolute; right: 10%; top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 190px; height: 190px;
    border: 1px solid rgba(212,192,165,.35);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; text-align: center;
}
.hero-badge span { font-size: 2.8rem; color: var(--gold-light); font-family: 'Cormorant Garamond', serif; font-weight: 300; }
.hero-badge small { font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: var(--beige-dark); }

/* ─── STATS ─── */
.stats-section {
    background: var(--cream-soft);
    border-top: 1px solid var(--beige-dark);
    border-bottom: 1px solid var(--beige-dark);
    padding: 56px 0;
}
.stat-item { text-align: center; }
.stat-item strong {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem; font-weight: 300;
    color: var(--brown); line-height: 1;
}
.stat-item span {
    font-size: .72rem; letter-spacing: 2px;
    text-transform: uppercase; color: var(--text-muted);
    margin-top: 8px; display: block;
}

/* ─── SECTIONS ─── */
.section { padding: 90px 0; }
.section-alt { background: var(--cream-soft); }
.section-header { text-align: center; margin-bottom: 56px; }
.section-header .eyebrow {
    font-size: .68rem; letter-spacing: 3px;
    text-transform: uppercase; color: var(--brown);
    display: block; margin-bottom: 16px;
}
.section-header h2 { margin-bottom: 16px; color: var(--brown-dark); }
.section-header p { max-width: 50ch; margin: 0 auto; color: var(--text-soft); }

/* ─── CARTES SERVICES ─── */
.service-card {
    background: var(--white);
    border: 1px solid var(--beige);
    border-radius: 8px; padding: 36px 28px;
    text-align: center;
    transition: all .3s ease;
}
.service-card:hover {
    border-color: var(--brown-light);
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(125,78,45,.12);
}
.service-icon {
    font-size: 2.6rem; margin-bottom: 18px; display: block;
}
.service-media {
    width: 100%; height: 180px;
    border-radius: 6px; margin-bottom: 18px;
    overflow: hidden;
}
.service-media img,
.service-media video {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
}
.service-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem; margin-bottom: 10px;
    color: var(--brown-dark);
}
.service-card p { font-size: .88rem; color: var(--text-soft); line-height: 1.7; }
.service-price {
    margin-top: 18px; font-size: .82rem;
    color: var(--brown); letter-spacing: 1px; font-weight: 500;
}

/* ─── CTA ─── */
.cta-section {
    padding: 90px 0;
    background: var(--brown-dark);
    text-align: center; position: relative; overflow: hidden;
}
.cta-section::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(196,147,63,.12) 0%, transparent 70%);
}
.cta-section .container { position: relative; z-index: 1; }
.cta-section h2 { margin-bottom: 16px; color: var(--cream); }
.cta-section p { margin-bottom: 36px; font-size: 1rem; color: var(--beige); }
.cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.cta-actions .btn {
    background: var(--cream);
    color: var(--brown-dark);
    border-color: var(--cream);
}
.cta-actions .btn:hover { background: var(--beige); }
.cta-actions .btn-outline {
    color: var(--cream);
    border-color: rgba(253,248,243,.4);
}
.cta-actions .btn-outline:hover {
    background: rgba(253,248,243,.08);
    border-color: var(--cream);
}

/* ─── POURQUOI NOUS ─── */
.why-item { display: flex; gap: 20px; align-items: flex-start; }
.why-icon {
    width: 52px; height: 52px; flex-shrink: 0;
    background: rgba(125,78,45,.1);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
}
.why-item h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; color: var(--brown-dark);
    margin-bottom: 6px;
}
.why-item p { font-size: .88rem; color: var(--text-soft); }

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
    .hero-badge { display: none; }
    .hero-content { padding: 60px 24px; }
}
@media (max-width: 700px) {
    .hero { min-height: 92vh; }
    .hero-content { padding: 48px 20px; }
    .hero h1 { font-size: clamp(2.4rem, 9vw, 3.5rem); max-width: none; }
    .hero p { font-size: .95rem; max-width: none; margin-bottom: 28px; }
    .hero-actions { flex-direction: column; gap: 12px; }
    .hero-actions a { text-align: center; justify-content: center; }
    .section { padding: 56px 0; }
    .section-header { margin-bottom: 36px; }
    .stats-section { padding: 36px 0; }
    .stat-item strong { font-size: 2.8rem; }
    .cta-section { padding: 60px 0; }
    .service-card { padding: 28px 20px; }
}
@media (max-width: 480px) {
    .hero h1 { font-size: 2.2rem; }
    .why-item { flex-direction: column; gap: 12px; }
}
</style>
{% endblock %}

{% block body %}

<!-- HERO -->
<section class="hero">
    {# Vidéo d'arrière-plan — dépose hero.mp4 dans public/videos/ #}
    <video class="hero-video" autoplay loop muted playsinline preload="auto"
           oncanplay="this.classList.add('loaded')">
        <source src="/videos/hero.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>

    <div class="hero-content">
        <span class="hero-eyebrow">✦ Salon de Beauté & Boutique · Bénin</span>
        <h1>L'art de la <em>beauté</em> à votre service</h1>
        <p>Coiffure femme & homme, bijoux et perruques de qualité. Prenez rendez-vous en ligne et commandez en toute simplicité.</p>
        <div class="hero-actions">
            <a href="{{ path('app_rdv') }}" class="btn">Prendre rendez-vous</a>
            <a href="{{ path('app_boutique') }}" class="btn-outline">Découvrir la boutique</a>
        </div>
    </div>
    <div class="hero-badge">
        <span>1+</span>
        <small>An d'expérience</small>
    </div>
</section>

<!-- STATS -->
<div class="stats-section">
    <div class="container">
        <div class="four-col">
            <div class="stat-item">
                <strong>500+</strong>
                <span>Clients satisfaits</span>
            </div>
            <div class="stat-item">
                <strong>6</strong>
                <span>Services premium</span>
            </div>
            <div class="stat-item">
                <strong>100+</strong>
                <span>Articles en boutique</span>
            </div>
            <div class="stat-item">
                <strong>5★</strong>
                <span>Note moyenne</span>
            </div>
        </div>
    </div>
</div>

<!-- SERVICES -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <span class="eyebrow">✦ Nos services</span>
            <h2>Une expérience beauté complète</h2>
            <div class="gold-line"></div>
            <p>Coiffure, ongles, perruques et entretien — tout ce dont vous avez besoin en un seul endroit.</p>
        </div>
        <div class="three-col">
            <div class="service-card">
                <div class="service-media">
                    <img src="/images/coiffure-femme.jpeg" alt="Coiffure Femme">
                </div>
                <h3>Coiffure Femme</h3>
                <p>Coupe, brushing, tresses, nattes, coloration et soins. Un style unique pour chaque femme.</p>
                <div class="service-price">À partir de 15 000 FCFA</div>
            </div>
            <div class="service-card">
                <div class="service-media">
                    <img src="/images/coiffure-homme.jpeg" alt="Coiffure Homme">
                </div>
                <h3>Coiffure Homme</h3>
                <p>Coupe, dégradé, barbe et soins capillaires. Un look soigné et tendance.</p>
                <div class="service-price">À partir de 5 000 FCFA</div>
            </div>
            <div class="service-card">
                <span class="service-icon">🧒</span>
                <h3>Coiffure Enfants</h3>
                <p>Coupes, tresses et nattes pour filles et garçons dans un cadre doux et adapté.</p>
                <div class="service-price">À partir de 3 000 FCFA</div>
            </div>
            <div class="service-card">
                <span class="service-icon">💅</span>
                <h3>Manucure & Pédicure</h3>
                <p>Pose de vernis, gel, faux ongles et soin des pieds. Des mains et pieds parfaits.</p>
                <div class="service-price">À partir de 5 000 FCFA</div>
            </div>
            <div class="service-card">
                <span class="service-icon">👱‍♀️</span>
                <h3>Perruques</h3>
                <p>Perruques naturelles et synthétiques de haute qualité pour changer de look.</p>
                <div class="service-price">À partir de 25 000 FCFA</div>
            </div>
            <div class="service-card">
                <span class="service-icon">✨</span>
                <h3>Entretien Perruques</h3>
                <p>Votre perruque a perdu de l'éclat ? On la remet à neuf — lavage, coiffage, réparation.</p>
                <div class="service-price">À partir de 8 000 FCFA</div>
            </div>
        </div>
    </div>
</section>

<!-- POURQUOI NOUS -->
<section class="section section-alt">
    <div class="container">
        <div class="two-col" style="align-items:center; gap: 60px;">
            <div>
                <span style="font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--brown);display:block;margin-bottom:16px;">✦ Pourquoi nous choisir</span>
                <h2 style="margin-bottom:24px;">Un salon de confiance, passionné depuis le premier jour</h2>
                <p style="margin-bottom:40px;">Chez BeautyAffair, chaque client est unique. Nous combinons savoir-faire traditionnel et tendances modernes pour vous offrir le meilleur.</p>
                <div style="display:flex;flex-direction:column;gap:28px;">
                    <div class="why-item">
                        <div class="why-icon">✂️</div>
                        <div>
                            <h4>Coiffeurs experts</h4>
                            <p>Notre équipe est formée aux dernières techniques et tendances capillaires africaines et internationales.</p>
                        </div>
                    </div>
                    <div class="why-item">
                        <div class="why-icon">📱</div>
                        <div>
                            <h4>Réservation en ligne</h4>
                            <p>Prenez rendez-vous 24h/24 depuis votre téléphone, sans attente et sans file.</p>
                        </div>
                    </div>
                    <div class="why-item">
                        <div class="why-icon">💳</div>
                        <div>
                            <h4>Paiement sécurisé</h4>
                            <p>Payez en ligne via Mobile Money (MTN, Moov) ou carte bancaire avec PayDunya.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div style="background:var(--beige);border-radius:12px;min-height:420px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;border:1px solid var(--beige-dark);">
                <span style="font-size:5rem;">💆‍♀️</span>
                <p style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--brown-dark);text-align:center;font-style:italic;max-width:20ch;">"La beauté est une expérience, pas seulement un résultat."</p>
                <small style="color:var(--text-muted);letter-spacing:2px;font-size:.7rem;text-transform:uppercase;">BeautyAffair</small>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
{% if not app.user %}
<section class="cta-section">
    <div class="container">
        <span style="display:block;font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--beige);margin-bottom:16px;">✦ Rejoignez-nous</span>
        <h2>Prête pour une nouvelle transformation ?</h2>
        <p>Créez votre compte et réservez votre premier rendez-vous en quelques clics.</p>
        <div class="cta-actions">
            <a href="{{ path('app_register') }}" class="btn">Créer mon compte</a>
            <a href="{{ path('app_login') }}" class="btn-outline">Se connecter</a>
        </div>
    </div>
</section>
{% endif %}

{% endblock %}
