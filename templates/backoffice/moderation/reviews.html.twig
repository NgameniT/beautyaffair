{% extends 'base.html.twig' %}

{% block title %}Modération commentaires | BiblioConnect{% endblock %}

{% block body %}

<div class="flex-between" style="margin-bottom:28px;">
    <div>
        <h1>Modération des commentaires</h1>
        <p>Approuvez ou rejetez les avis en attente de validation.</p>
    </div>
    <a class="btn-ghost btn-xs" href="{{ path('app_admin_dashboard') }}" style="text-decoration:none;">← Tableau de bord</a>
</div>

{% if reviews is empty %}
    <div class="card card-body empty-state">
        <div class="empty-icon">✅</div>
        <h3>Aucun avis en attente</h3>
        <p>Tous les commentaires ont été traités.</p>
    </div>
{% else %}
    <div style="display:flex;flex-direction:column;gap:16px;">
        {% for review in reviews %}
            <div class="card card-body" style="display:flex;justify-content:space-between;align-items:flex-start;gap:20px;flex-wrap:wrap;">
                <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap;">
                        <strong style="color:var(--g900);">{{ review.book.title }}</strong>
                        <span class="stars-display" style="font-size:.85rem;">{% for i in 1..5 %}{{ i <= review.rating ? '★' : '☆' }}{% endfor %}</span>
                        <span class="badge badge-pending">En attente</span>
                    </div>
                    <p style="font-size:.8rem;color:var(--g500);margin-bottom:8px;">{{ review.user.fullName ?: review.user.userIdentifier }} · {{ review.createdAt|date('d/m/Y H:i') }}</p>
                    <p style="font-size:.9rem;color:var(--g700);line-height:1.65;">{{ review.comment }}</p>
                </div>
                <div style="display:flex;gap:8px;flex-shrink:0;">
                    <form method="post" action="{{ path('app_admin_review_approve', {id: review.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve-review-' ~ review.id) }}">
                        <button class="btn-ok btn-xs" type="submit">✓ Approuver</button>
                    </form>
                    <form method="post" action="{{ path('app_admin_review_reject', {id: review.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('reject-review-' ~ review.id) }}">
                        <button class="btn-danger-sm btn-xs" type="submit">✕ Rejeter</button>
                    </form>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}
