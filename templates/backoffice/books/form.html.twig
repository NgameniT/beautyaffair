{% extends 'base.html.twig' %}

{% block title %}{{ isEdition ? 'Modifier' : 'Ajouter' }} un ouvrage | BiblioConnect{% endblock %}

{% block body %}

<div style="margin-bottom:32px;">
    <a class="btn-ghost btn-xs" href="{{ path(redirectRoute) }}" style="text-decoration:none;">← Retour au catalogue</a>
    <h1 style="margin-top:12px;margin-bottom:8px;">{{ isEdition ? 'Modifier l\'ouvrage' : 'Ajouter un nouvel ouvrage' }}</h1>
    <p style="color:var(--g500);margin-top:4px;">Complétez les informations ci-dessous pour {{ isEdition ? 'mettre à jour' : 'créer' }} le livre.</p>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
    <!-- Formulaire -->
    <div>
        <div class="card card-body">
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

            <!-- Infos principales -->
            <div style="margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--g100);">
                <h3 style="font-size:.92rem;color:var(--g700);font-weight:600;margin-bottom:16px;text-transform:uppercase;letter-spacing:.5px;color:var(--g500);">Informations principales</h3>
                
                <div class="field" style="margin-bottom:16px;">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title, {attr: {class: 'form-control', placeholder: 'Ex: Le Petit Prince'}}) }}
                    {% if form.title.vars.errors %}
                        <div style="color:#d32f2f;font-size:.78rem;margin-top:4px;">
                            {% for error in form.title.vars.errors %}{{ error.message }}{% endfor %}
                        </div>
                    {% endif %}
                </div>

                <div class="field" style="margin-bottom:16px;">
                    {{ form_label(form.author) }}
                    {{ form_widget(form.author, {attr: {class: 'form-control', placeholder: 'Ex: Antoine de Saint-Exupéry'}}) }}
                    {% if form.author.vars.errors %}
                        <div style="color:#d32f2f;font-size:.78rem;margin-top:4px;">
                            {% for error in form.author.vars.errors %}{{ error.message }}{% endfor %}
                        </div>
                    {% endif %}
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="field">
                        {{ form_label(form.category) }}
                        {{ form_widget(form.category, {attr: {class: 'form-control'}}) }}
                        {% if form.category.vars.errors %}
                            <div style="color:#d32f2f;font-size:.78rem;margin-top:4px;">
                                {% for error in form.category.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    <div class="field">
                        {{ form_label(form.language) }}
                        {{ form_widget(form.language, {attr: {class: 'form-control'}}) }}
                        {% if form.language.vars.errors %}
                            <div style="color:#d32f2f;font-size:.78rem;margin-top:4px;">
                                {% for error in form.language.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div style="margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--g100);">
                <h3 style="font-size:.92rem;color:var(--g700);font-weight:600;margin-bottom:16px;text-transform:uppercase;letter-spacing:.5px;color:var(--g500);">Contenu</h3>
                
                <div class="field">
                    {{ form_label(form.summary) }}
                    {{ form_widget(form.summary, {attr: {class: 'form-control', placeholder: 'Décrivez le contenu du livre en quelques lignes...', rows: 5}}) }}
                    {% if form.summary.vars.errors %}
                        <div style="color:#d32f2f;font-size:.78rem;margin-top:4px;">
                            {% for error in form.summary.vars.errors %}{{ error.message }}{% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Métadonnées -->
            <div style="margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--g100);">
                <h3 style="font-size:.92rem;color:var(--g700);font-weight:600;margin-bottom:16px;text-transform:uppercase;letter-spacing:.5px;color:var(--g500);">Métadonnées</h3>
                
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                    <div class="field">
                        {{ form_label(form.publishedYear) }}
                        {{ form_widget(form.publishedYear, {attr: {class: 'form-control', placeholder: 'Ex: 1943', type: 'number'}}) }}
                    </div>
                    <div class="field">
                        {{ form_label(form.pageCount) }}
                        {{ form_widget(form.pageCount, {attr: {class: 'form-control', placeholder: 'Ex: 96', type: 'number'}}) }}
                    </div>
                </div>

                <div class="field" style="margin-bottom:16px;">
                    {{ form_label(form.coverTheme) }}
                    {{ form_widget(form.coverTheme, {attr: {class: 'form-control'}}) }}
                </div>

                <div class="field">
                    {{ form_label(form.slug) }}
                    {{ form_widget(form.slug, {attr: {class: 'form-control', placeholder: 'Ex: le-petit-prince'}}) }}
                    {% if form.slug.vars.errors %}
                        <div style="color:#d32f2f;font-size:.78rem;margin-top:4px;">
                            {% for error in form.slug.vars.errors %}{{ error.message }}{% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Stock et visibilité -->
            <div style="margin-bottom:24px;">
                <h3 style="font-size:.92rem;color:var(--g700);font-weight:600;margin-bottom:16px;text-transform:uppercase;letter-spacing:.5px;color:var(--g500);">Stock & visibilité</h3>
                
                <div class="field" style="margin-bottom:16px;">
                    {{ form_label(form.availableCopies) }}
                    {{ form_widget(form.availableCopies, {attr: {class: 'form-control', placeholder: 'Ex: 5', type: 'number'}}) }}
                    {% if form.availableCopies.vars.errors %}
                        <div style="color:#d32f2f;font-size:.78rem;margin-top:4px;">
                            {% for error in form.availableCopies.vars.errors %}{{ error.message }}{% endfor %}
                        </div>
                    {% endif %}
                </div>

                <div class="field" style="margin-bottom:16px;">
                    {{ form_label(form.imageUrl) }}
                    {{ form_widget(form.imageUrl, {attr: {class: 'form-control', placeholder: 'https://example.com/image.jpg'}}) }}
                    <p style="font-size:.75rem;color:var(--g400);margin-top:4px;">{{ form.imageUrl.vars.help|default('') }}</p>
                </div>

                <div style="background:var(--g50);padding:12px 14px;border-radius:var(--r-sm);border:1px solid var(--g200);">
                    <label style="display:flex;align-items:center;gap:10px;cursor:pointer;margin-bottom:0;">
                        {{ form_widget(form.featured) }}
                        <span style="font-weight:500;color:var(--g700);">Mettre en avant (page d'accueil)</span>
                    </label>
                    <p style="font-size:.75rem;color:var(--g500);margin-top:6px;">{{ form.featured.vars.help|default('') }}</p>
                </div>
            </div>

            <!-- Boutons d'action -->
            <div style="display:flex;gap:12px;padding-top:20px;border-top:1px solid var(--g100);">
                <button class="btn" type="submit" style="flex:1;">
                    {% if isEdition %}
                        ✓ Enregistrer les modifications
                    {% else %}
                        ✓ Créer l'ouvrage
                    {% endif %}
                </button>
                <a class="btn-outline" href="{{ path(redirectRoute) }}" style="text-decoration:none;">Annuler</a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    <!-- Panneau latéral (aperçu & aide) -->
    <div>
        <div class="card" style="position:sticky;top:100px;">
            <div class="card-body">
                <h3 style="font-size:.92rem;color:var(--g700);font-weight:600;margin-bottom:16px;text-transform:uppercase;letter-spacing:.5px;">Aperçu</h3>
                
                {% if form.title.vars.data or form.vars.data.title %}
                    <div style="margin-bottom:20px;padding:14px;background:var(--g50);border-radius:var(--r-sm);border:1px solid var(--g200);">
                        <div style="text-align:center;">
                            {% set theme = form.coverTheme.vars.data or form.vars.data.coverTheme or 'yellow' %}
                            <div class="book-cover theme-{{ theme }}" style="height:120px;display:flex;flex-direction:column;justify-content:flex-end;padding:14px;margin-bottom:12px;border-radius:var(--r-sm);">
                                <h4 style="color:var(--white);font-size:.85rem;font-weight:600;line-height:1.2;">{{ form.title.vars.data or form.vars.data.title or 'Titre du livre' }}</h4>
                            </div>
                            <p style="font-size:.82rem;color:var(--g600);margin-bottom:6px;">{{ form.author.vars.data or form.vars.data.author or 'Auteur inconnu' }}</p>
                            <p style="font-size:.75rem;color:var(--g400);">{{ form.category.vars.data or form.vars.data.category or 'Catégorie' }}</p>
                        </div>
                    </div>
                {% endif %}

                <div style="background:#f0f7ff;padding:12px 14px;border-radius:var(--r-sm);margin-bottom:16px;border-left:3px solid #3b82f6;">
                    <p style="font-size:.78rem;color:#1e40af;margin-bottom:8px;"><strong>💡 Conseils :</strong></p>
                    <ul style="list-style:none;padding:0;margin:0;font-size:.75rem;color:#1e40af;line-height:1.6;">
                        <li>✓ Le slug doit être unique et sans majuscules</li>
                        <li>✓ Utilisez des mots-clés clairs pour la catégorie</li>
                        <li>✓ La description aide à la recherche</li>
                        <li>✓ Sélectionnez le bon thème visuel</li>
                    </ul>
                </div>

                <div style="color:var(--g500);font-size:.75rem;line-height:1.5;">
                    <p><strong>Stock :</strong> {{ form.availableCopies.vars.data or form.vars.data.availableCopies or 0 }} copie(s)</p>
                    <p style="margin-top:4px;"><strong>Pages :</strong> {{ form.pageCount.vars.data or form.vars.data.pageCount or '—' }}</p>
                    <p style="margin-top:4px;"><strong>Année :</strong> {{ form.publishedYear.vars.data or form.vars.data.publishedYear or '—' }}</p>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

