{% extends 'base.html.twig' %}

{% block title %}{{ title }} | BiblioConnect{% endblock %}

{% block body %}

<div class="flex-between" style="margin-bottom:28px;">
    <div>
        <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--g400);margin-bottom:6px;">{{ title }}</span>
        <h1>Gestion du catalogue</h1>
    </div>
    <div class="flex-gap">
        <a class="btn-ghost btn-xs" href="{{ path(dashboardRoute) }}" style="text-decoration:none;">← Tableau de bord</a>
        <a class="btn btn-xs" href="{{ path(newRoute) }}" style="text-decoration:none;">+ Ajouter un ouvrage</a>
    </div>
</div>

<div class="card" style="overflow:hidden;">
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Auteur</th>
                    <th>Catégorie</th>
                    <th>Langue</th>
                    <th>Stock</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for book in books %}
                    <tr>
                        <td style="font-weight:600;color:var(--g900);">{{ book.title }}</td>
                        <td>{{ book.author }}</td>
                        <td><span class="badge">{{ book.category }}</span></td>
                        <td>{{ book.language }}</td>
                        <td>
                            {% if book.availableCopies > 0 %}
                                <span class="badge badge-ok">{{ book.availableCopies }}</span>
                            {% else %}
                                <span class="badge badge-alert">0</span>
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex;gap:8px;">
                                <a class="btn-outline btn-xs" href="{{ path(editRoute, {id: book.id}) }}" style="text-decoration:none;">Modifier</a>
                                <form method="post" action="{{ path(deleteRoute, {id: book.id}) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet ouvrage ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-book-' ~ book.id) }}">
                                    <button class="btn-outline btn-xs" type="submit" style="color:#d32f2f;border-color:#d32f2f;">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--g400);">Aucun ouvrage dans le catalogue.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
