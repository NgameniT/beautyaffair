{% extends 'base.html.twig' %}

{% block title %}{% if isEdition %}Éditer{% else %}Ajouter{% endif %} utilisateur | BiblioConnect{% endblock %}

{% block body %}

<div style="margin-bottom:28px;">
    <a class="btn-ghost btn-xs" href="{{ path('app_admin_users') }}" style="text-decoration:none;">← Retour</a>
    <h1 style="margin-top:12px;">{% if isEdition %}Modifier l'utilisateur{% else %}Créer un nouvel utilisateur{% endif %}</h1>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        {{ form_start(form, { attr: { 'data-turbo': 'false' } }) }}

        {% if form.vars.errors|length > 0 %}
            <div style="background:#ffe8e8;border:1px solid #ffb3b3;color:#8a1f1f;padding:12px 14px;border-radius:10px;margin-bottom:16px;">
                {% for error in form.vars.errors %}
                    <div>{{ error.message }}</div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="field" style="margin-bottom:20px;">
            {{ form_label(form.prenom) }}
            {{ form_widget(form.prenom, {attr: {class: 'form-control', placeholder: 'Prénom'}}) }}
            {% if form.prenom.vars.errors %}
                <div style="color:var(--red);font-size:.78rem;margin-top:4px;">
                    {% for error in form.prenom.vars.errors %}{{ error.message }}{% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="field" style="margin-bottom:20px;">
            {{ form_label(form.nom) }}
            {{ form_widget(form.nom, {attr: {class: 'form-control', placeholder: 'Nom'}}) }}
            {% if form.nom.vars.errors %}
                <div style="color:var(--red);font-size:.78rem;margin-top:4px;">
                    {% for error in form.nom.vars.errors %}{{ error.message }}{% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="field" style="margin-bottom:20px;">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {attr: {class: 'form-control', placeholder: 'mail@exemple.fr', type: 'email'}}) }}
            {% if form.email.vars.errors %}
                <div style="color:var(--red);font-size:.78rem;margin-top:4px;">
                    {% for error in form.email.vars.errors %}{{ error.message }}{% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="field" style="margin-bottom:20px;">
            {{ form_label(form.roles) }}
            {{ form_widget(form.roles, {attr: {class: 'form-control'}}) }}
            {% if form.roles.vars.errors %}
                <div style="color:var(--red);font-size:.78rem;margin-top:4px;">
                    {% for error in form.roles.vars.errors %}{{ error.message }}{% endfor %}
                </div>
            {% endif %}
        </div>

        {% if form.plainPassword is defined %}
            <div style="font-size:.82rem;color:var(--text-muted);margin-bottom:10px;">
                Mot de passe: 8 caracteres minimum, avec au moins 1 majuscule, 1 minuscule et 1 chiffre.
            </div>

            {% if form.plainPassword.vars.errors|length > 0 %}
                <div style="background:#ffe8e8;border:1px solid #ffb3b3;color:#8a1f1f;padding:10px 12px;border-radius:8px;margin-bottom:14px;">
                    {% for error in form.plainPassword.vars.errors %}
                        <div>{{ error.message }}</div>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="field" style="margin-bottom:20px;">
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first, {attr: {class: 'form-control', placeholder: '••••••••', autocomplete: 'new-password'}}) }}
                {% if form.plainPassword.first.vars.errors %}
                    <div style="color:var(--red);font-size:.78rem;margin-top:4px;">
                        {% for error in form.plainPassword.first.vars.errors %}{{ error.message }}{% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="field" style="margin-bottom:20px;">
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second, {attr: {class: 'form-control', placeholder: '••••••••', autocomplete: 'new-password'}}) }}
                {% if form.plainPassword.second.vars.errors %}
                    <div style="color:var(--red);font-size:.78rem;margin-top:4px;">
                        {% for error in form.plainPassword.second.vars.errors %}{{ error.message }}{% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endif %}

        <div style="display:flex;gap:12px;margin-top:28px;">
            <button class="btn btn-xs" type="submit">{% if isEdition %}Enregistrer{% else %}Créer{% endif %}</button>
            <a class="btn-outline btn-xs" href="{{ path('app_admin_users') }}" style="text-decoration:none;">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

{% endblock %}
