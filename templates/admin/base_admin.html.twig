{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
.admin-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: calc(100vh - 70px);
    align-items: start;
}

/* ─── SIDEBAR ─── */
.admin-sidebar {
    background: var(--brown-dark);
    min-height: calc(100vh - 70px);
    padding: 24px 0;
    position: sticky;
    top: 70px;
}
.sidebar-title {
    padding: 0 20px 16px;
    font-size: .65rem; letter-spacing: 3px;
    text-transform: uppercase; color: var(--beige-dark);
    border-bottom: 1px solid rgba(212,192,165,.15);
    margin-bottom: 8px;
}
.sidebar-nav { list-style: none; }
.sidebar-nav a {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 20px;
    font-size: .875rem; color: var(--beige-dark);
    text-decoration: none;
    transition: var(--ease);
    border-left: 3px solid transparent;
}
.sidebar-nav a:hover,
.sidebar-nav a.active {
    color: var(--cream);
    background: rgba(253,248,243,.07);
    border-left-color: var(--gold);
}
.sidebar-nav a svg { width: 16px; height: 16px; flex-shrink: 0; }
.sidebar-section {
    padding: 16px 20px 6px;
    font-size: .6rem; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(212,192,165,.5);
    margin-top: 8px;
}

/* ─── CONTENU ─── */
.admin-content { padding: 36px 40px; background: var(--cream); }

/* ─── PAGE HEADER ─── */
.admin-page-header {
    display: flex; align-items: center;
    justify-content: space-between; gap: 16px;
    margin-bottom: 32px; flex-wrap: wrap;
}
.admin-page-header h1 {
    font-size: 1.8rem; color: var(--brown-dark);
}
.admin-breadcrumb {
    font-size: .78rem; color: var(--text-muted);
    margin-bottom: 4px;
}
.admin-breadcrumb a { color: var(--brown); text-decoration: none; }
.admin-breadcrumb a:hover { text-decoration: underline; }

/* ─── STAT CARDS ─── */
.stat-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 32px; }
.stat-card {
    background: var(--white);
    border: 1px solid var(--beige);
    border-radius: 10px; padding: 20px 24px;
    border-left: 4px solid var(--brown);
}
.stat-card .label { font-size: .72rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
.stat-card .value { font-size: 2rem; font-weight: 300; font-family: 'Cormorant Garamond', serif; color: var(--brown-dark); line-height: 1; }
.stat-card .sub   { font-size: .78rem; color: var(--text-muted); margin-top: 4px; }
.stat-card.accent { border-left-color: var(--gold); }
.stat-card.green  { border-left-color: #16a34a; }
.stat-card.red    { border-left-color: #dc2626; }

/* ─── TABLE ADMIN ─── */
.admin-table-wrap { background: var(--white); border: 1px solid var(--beige); border-radius: 10px; overflow: hidden; }
.admin-table-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 24px; border-bottom: 1px solid var(--beige);
    flex-wrap: wrap; gap: 12px;
}
.admin-table-header h2 { font-size: 1.1rem; color: var(--brown-dark); }
.admin-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
.admin-table thead th {
    text-align: left; padding: 12px 20px;
    font-size: .68rem; font-weight: 600;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--brown); background: var(--cream-soft);
    border-bottom: 1px solid var(--beige);
}
.admin-table tbody td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--beige);
    color: var(--text-soft); vertical-align: middle;
}
.admin-table tbody tr:last-child td { border-bottom: none; }
.admin-table tbody tr:hover td { background: rgba(125,78,45,.025); }

/* ─── BADGES STATUT ─── */
.badge-pill {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 20px;
    font-size: .7rem; font-weight: 500; letter-spacing: .3px;
    white-space: nowrap;
}
.badge-attente  { background: rgba(196,147,63,.12); color: #92400e; }
.badge-confirme { background: rgba(22,163,74,.1);   color: #166534; }
.badge-annule   { background: rgba(220,38,38,.1);   color: #991b1b; }
.badge-termine  { background: rgba(125,78,45,.1);   color: var(--brown-dark); }
.badge-actif    { background: rgba(22,163,74,.1);   color: #166534; }
.badge-inactif  { background: rgba(156,163,175,.15); color: #6b7280; }
.badge-admin    { background: rgba(125,78,45,.15);  color: var(--brown); }
.badge-user     { background: rgba(99,102,241,.1);  color: #4338ca; }

/* ─── ACTION BUTTONS ─── */
.action-btns { display: flex; gap: 6px; flex-wrap: wrap; }
.btn-sm {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 5px 12px; border-radius: 4px;
    font-size: .75rem; font-weight: 500; letter-spacing: .5px;
    text-transform: uppercase; cursor: pointer;
    border: 1px solid transparent; font-family: 'Jost', sans-serif;
    text-decoration: none; transition: var(--ease);
    white-space: nowrap;
}
.btn-sm-primary { background: var(--brown); color: var(--white); border-color: var(--brown); }
.btn-sm-primary:hover { background: var(--brown-dark); border-color: var(--brown-dark); }
.btn-sm-success { background: rgba(22,163,74,.1); color: #166534; border-color: rgba(22,163,74,.3); }
.btn-sm-success:hover { background: rgba(22,163,74,.2); }
.btn-sm-danger  { background: rgba(220,38,38,.08); color: #991b1b; border-color: rgba(220,38,38,.25); }
.btn-sm-danger:hover  { background: rgba(220,38,38,.15); }
.btn-sm-neutral { background: var(--cream-soft); color: var(--text-soft); border-color: var(--beige-dark); }
.btn-sm-neutral:hover { background: var(--beige); }

@media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; min-height: auto; }
    .stat-grid { grid-template-columns: 1fr 1fr; }
    .admin-content { padding: 24px 16px; }
}
</style>
{% endblock %}

{% block body %}
<div class="admin-layout">

    <!-- SIDEBAR -->
    <aside class="admin-sidebar">
        <div class="sidebar-title">BeautyAffair · Admin</div>
        <ul class="sidebar-nav">
            <li>
                <a href="{{ path('app_admin_dashboard') }}" class="{{ app.request.attributes.get('_route') == 'app_admin_dashboard' ? 'active' : '' }}">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Tableau de bord
                </a>
            </li>
            <div class="sidebar-section">Gestion</div>
            <li>
                <a href="{{ path('app_admin_rdv_list') }}" class="{{ app.request.attributes.get('_route') starts with 'app_admin_rdv' ? 'active' : '' }}">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Rendez-vous
                </a>
            </li>
            <li>
                <a href="{{ path('app_admin_produits') }}" class="{{ app.request.attributes.get('_route') starts with 'app_admin_produit' ? 'active' : '' }}">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    Produits
                </a>
            </li>
            <li>
                <a href="{{ path('app_admin_users') }}" class="{{ app.request.attributes.get('_route') starts with 'app_admin_user' ? 'active' : '' }}">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Utilisateurs
                </a>
            </li>
            <div class="sidebar-section">Site</div>
            <li>
                <a href="{{ path('app_home') }}" target="_blank">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Voir le site
                </a>
            </li>
        </ul>
    </aside>

    <!-- CONTENU -->
    <div class="admin-content">
        {% block admin_body %}{% endblock %}
    </div>

</div>
{% endblock %}
