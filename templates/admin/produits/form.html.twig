{% extends 'admin/base_admin.html.twig' %}
{% block title %}{{ titre }} · Admin{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.form-card {
    background: var(--white);
    border: 1px solid var(--beige);
    border-radius: 10px;
    padding: 32px 40px;
    max-width: 640px;
}
.form-group { margin-bottom: 22px; }
.form-group label {
    display: block;
    font-size: .78rem; font-weight: 600;
    letter-spacing: 1px; text-transform: uppercase;
    color: var(--brown-dark); margin-bottom: 8px;
}
.form-group input,
.form-group textarea,
.form-group select {
    width: 100%; padding: 10px 14px;
    border: 1px solid var(--beige-dark);
    border-radius: 6px; font-size: .9rem;
    font-family: 'Jost', sans-serif;
    color: var(--text); background: var(--cream);
    transition: border-color .2s;
    box-sizing: border-box;
}
.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
    outline: none;
    border-color: var(--brown);
    background: var(--white);
}
.form-group textarea { resize: vertical; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.form-error { color: #dc2626; font-size: .8rem; margin-top: 5px; }
.form-actions {
    display: flex; gap: 12px; align-items: center;
    margin-top: 32px; padding-top: 24px;
    border-top: 1px solid var(--beige);
}
</style>
{% endblock %}

{% block admin_body %}

<div class="admin-page-header">
    <div>
        <div class="admin-breadcrumb">
            <a href="{{ path('app_admin_dashboard') }}">Admin</a> /
            <a href="{{ path('app_admin_produits') }}">Produits</a> /
            {{ titre }}
        </div>
        <h1>{{ titre }}</h1>
    </div>
</div>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div style="background:{% if label=='success' %}rgba(22,163,74,.1){% else %}rgba(220,38,38,.1){% endif %};border:1px solid {% if label=='success' %}rgba(22,163,74,.3){% else %}rgba(220,38,38,.3){% endif %};color:{% if label=='success' %}#166534{% else %}#991b1b{% endif %};padding:12px 16px;border-radius:6px;margin-bottom:20px;font-size:.875rem;">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{{ form_start(form, {action: produit.id ? path('app_admin_produit_edit', {id: produit.id}) : path('app_admin_produit_new'), method: 'POST', attr: {'enctype': 'multipart/form-data'}}) }}

<div class="form-card">

    <div class="form-group">
        {{ form_label(form.nom) }}
        {{ form_widget(form.nom) }}
        {{ form_errors(form.nom) }}
    </div>

    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.prix) }}
            {{ form_widget(form.prix) }}
            {{ form_errors(form.prix) }}
        </div>
        <div class="form-group">
            {{ form_label(form.stock) }}
            {{ form_widget(form.stock) }}
            {{ form_errors(form.stock) }}
        </div>
    </div>

    <div class="form-group">
        {{ form_label(form.categorie) }}
        {{ form_widget(form.categorie) }}
        {{ form_errors(form.categorie) }}
    </div>

    <div class="form-group">
        {{ form_label(form.imageFile) }}
        {% if produit.image %}
            <div style="margin-bottom:10px;display:flex;align-items:center;gap:14px;">
                <img src="/uploads/produits/{{ produit.image }}" alt="{{ produit.nom }}"
                     style="width:80px;height:80px;object-fit:cover;border-radius:6px;border:1px solid var(--beige);">
                <span style="font-size:.8rem;color:var(--text-muted);">Photo actuelle — laissez vide pour la conserver</span>
            </div>
        {% endif %}
        {{ form_widget(form.imageFile) }}
        {{ form_errors(form.imageFile) }}
        <div style="font-size:.75rem;color:var(--text-muted);margin-top:5px;">{{ form_help(form.imageFile) }}</div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-sm btn-sm-primary" style="padding:10px 28px;font-size:.85rem;">
            {% if produit.id %}Enregistrer les modifications{% else %}Créer le produit{% endif %}
        </button>
        <a href="{{ path('app_admin_produits') }}" class="btn-sm btn-sm-neutral" style="padding:10px 20px;font-size:.85rem;">Annuler</a>
    </div>

</div>

{{ form_end(form) }}

{% endblock %}
