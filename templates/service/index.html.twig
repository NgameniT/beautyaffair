{% extends 'base.html.twig' %}
{% block title %}Services Coiffure · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.page-header {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 100%);
    padding: 72px 0 56px;
    text-align: center;
    position: relative; overflow: hidden;
}
.page-header::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 100%, rgba(196,147,63,.15) 0%, transparent 65%);
}
.page-header .container { position: relative; z-index: 1; }
.page-header .eyebrow {
    font-size: .68rem; letter-spacing: 3px;
    text-transform: uppercase; color: var(--beige);
    display: block; margin-bottom: 14px;
}
.page-header h1 { color: var(--cream); margin-bottom: 14px; }
.page-header p { color: var(--beige-dark); max-width: 48ch; margin: 0 auto; }

.section { padding: 80px 0; }
.section-alt { background: var(--cream-soft); }
.section-header { text-align: center; margin-bottom: 52px; }
.section-header .eyebrow {
    font-size: .68rem; letter-spacing: 3px;
    text-transform: uppercase; color: var(--brown);
    display: block; margin-bottom: 14px;
}
.section-header h2 { color: var(--brown-dark); margin-bottom: 14px; }

/* ── TARIFS ── */
.prestation-card {
    background: var(--white);
    border: 1px solid var(--beige);
    border-radius: 8px;
    overflow: hidden;
    transition: all .3s ease;
}
.prestation-card:hover {
    border-color: var(--brown-light);
    box-shadow: 0 12px 40px rgba(125,78,45,.12);
    transform: translateY(-4px);
}
.prestation-header {
    background: var(--cream-soft);
    border-bottom: 1px solid var(--beige);
    padding: 28px 24px;
    display: flex; align-items: center; gap: 16px;
}
.svc-icon {
    width: 48px; height: 48px; flex-shrink: 0;
    background: rgba(125,78,45,.09);
    border-radius: 50%;
    border: 1px solid rgba(125,78,45,.2);
    display: flex; align-items: center; justify-content: center;
}
.svc-icon svg { width: 22px; height: 22px; }
.prestation-header h3 { color: var(--brown-dark); margin: 0; }
.prestation-header small { color: var(--text-muted); font-size: .78rem; }
.prestation-list { padding: 20px 24px; list-style: none; }
.prestation-list li {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--beige);
    font-size: .9rem;
}
.prestation-list li:last-child { border-bottom: none; }
.prestation-list .name { color: var(--text); }
.prestation-list .price { color: var(--brown); font-weight: 500; font-size: .85rem; white-space: nowrap; }
.prestation-footer { padding: 16px 24px; border-top: 1px solid var(--beige); text-align: center; }

/* ── GALERIE RÉALISATIONS ── */
.galerie-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}
.galerie-card {
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: var(--white);
    border: 1px solid var(--beige);
    transition: all .3s ease;
    cursor: pointer;
}
.galerie-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(125,78,45,.18);
    border-color: var(--brown-light);
}
.galerie-photo {
    height: 260px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}
.galerie-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
}
.galerie-card:hover .galerie-photo img { transform: scale(1.06); }

/* Placeholder quand pas de vraie photo */
.galerie-photo.placeholder {
    font-size: 5rem;
    flex-direction: column;
    gap: 8px;
}
.galerie-photo.placeholder::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(0,0,0,.05);
}

/* Overlay au hover */
.galerie-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(58,24,6,.85) 0%, transparent 55%);
    opacity: 0;
    transition: opacity .3s ease;
    display: flex; align-items: flex-end;
    padding: 20px;
}
.galerie-card:hover .galerie-overlay { opacity: 1; }
.galerie-overlay-content { color: var(--cream); }
.galerie-overlay-content .ov-name { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 600; display: block; margin-bottom: 2px; }
.galerie-overlay-content .ov-price { font-size: .82rem; color: var(--gold); letter-spacing: 1px; }

/* Infos sous la photo */
.galerie-info {
    padding: 14px 16px;
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid var(--beige);
}
.galerie-info .g-name { font-size: .92rem; color: var(--brown-dark); font-weight: 500; }
.galerie-info .g-price {
    font-size: .88rem; color: var(--brown); font-weight: 600;
    background: rgba(125,78,45,.08); border-radius: 4px;
    padding: 3px 10px;
}

/* Note upload */
.upload-note {
    text-align: center;
    margin-top: 36px;
    padding: 16px 24px;
    background: rgba(196,147,63,.07);
    border: 1px dashed var(--gold);
    border-radius: 8px;
    font-size: .82rem;
    color: var(--text-muted);
}
.upload-note strong { color: var(--brown); }

/* ── CTA RDV ── */
.rdv-section {
    background: var(--brown-dark);
    padding: 80px 0; text-align: center;
    position: relative; overflow: hidden;
}
.rdv-section::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(196,147,63,.1) 0%, transparent 70%);
}
.rdv-section .container { position: relative; z-index: 1; }
.rdv-section h2 { color: var(--cream); margin-bottom: 14px; }
.rdv-section p { color: var(--beige); margin-bottom: 36px; max-width: 50ch; margin-left: auto; margin-right: auto; }

@media (max-width: 900px) { .galerie-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .galerie-grid { grid-template-columns: 1fr; } .galerie-photo { height: 220px; } }
</style>
{% endblock %}

