{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} | BiblioConnect{% endblock %}

{% block body %}

<!-- Retour catalogue -->
<div style="margin-bottom:24px;">
    <a class="btn-ghost btn-xs" href="{{ path('app_catalogue') }}" style="text-decoration:none;">← Retour au catalogue</a>
</div>

<!-- Ligne principale -->
<div class="sidebar-layout" style="gap:28px;margin-bottom:28px;">

    <!-- Carte livre -->
    <div>
        <div class="card" style="overflow:hidden;">
            <div class="book-cover theme-{{ book.coverTheme }}" style="min-height:220px;padding:32px 28px;">
                <div class="cover-chips">
                    <span class="cover-chip">{{ book.category }}</span>
                    <span class="cover-chip">{{ book.publishedYear }}</span>
                    {% if book.featured %}<span class="cover-chip">★ Sélection</span>{% endif %}
                </div>
                <div>
                    <div style="font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:8px;">Collection BiblioConnect</div>
                    <h1 style="color:#fff;font-size:clamp(1.6rem,4vw,2.8rem);margin-bottom:6px;">{{ book.title }}</h1>
                    <p style="color:rgba(255,255,255,.8);font-size:.95rem;">{{ book.author }}</p>
                    {% if averageRating > 0 %}
                        <p style="color:rgba(255,255,255,.9);margin-top:8px;font-size:.85rem;">
                            <span style="color:#fbbf24;">{% for i in 1..5 %}{{ i <= averageRating ? '★' : '☆' }}{% endfor %}</span>
                            {{ averageRating }}/5
                        </p>
                    {% endif %}
                </div>
            </div>
            <div class="card-body">
                <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--g400);margin-bottom:10px;">À propos du livre</span>
                <p style="font-size:.9rem;line-height:1.75;color:var(--g700);">{{ book.summary }}</p>
                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:16px;">
                    <span class="badge">{{ book.category }}</span>
                    <span class="badge">{{ book.language }}</span>
                    <span class="badge">{{ book.publishedYear }}</span>
                    <span class="badge">{{ book.pageCount }} pages</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Panneau latéral -->
    <div style="display:flex;flex-direction:column;gap:20px;">

        <!-- Disponibilité -->
        <div class="card card-body">
            <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--g400);margin-bottom:14px;">Disponibilité</span>
            <div class="item-list">
                <div class="item-row" style="padding-top:0;">
                    <div><span class="item-title">{{ book.pageCount }} pages</span><span class="item-meta">Format de l'ouvrage</span></div>
                </div>
                <div class="item-row">
                    <div>
                        <span class="item-title">{{ book.availableCopies }} exemplaire{{ book.availableCopies > 1 ? 's' : '' }}</span>
                        <span class="item-meta">disponible{{ book.availableCopies > 1 ? 's' : '' }} en ce moment</span>
                    </div>
                    {% if book.availableCopies > 0 %}
                        <span class="badge badge-ok">Disponible</span>
                    {% else %}
                        <span class="badge badge-alert">Indisponible</span>
                    {% endif %}
                </div>
                <div class="item-row">
                    <div><span class="item-title">{{ book.language }}</span><span class="item-meta">Langue de l'ouvrage</span></div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="card card-body">
            <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--g400);margin-bottom:14px;">Actions</span>

            {% if app.user %}
                <!-- Favoris -->
                <div style="margin-bottom:14px;">
                    {% if isFavorite %}
                        <form method="post" action="{{ path('app_catalogue_unfavorite', {id: book.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('unfavorite-book-' ~ book.id) }}">
                            <button class="btn-outline btn-xs" type="submit" style="width:100%;justify-content:center;padding:9px;">🔖 Retirer des favoris</button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('app_catalogue_favorite', {id: book.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('favorite-book-' ~ book.id) }}">
                            <button class="btn-outline btn-xs" type="submit" style="width:100%;justify-content:center;padding:9px;">♡ Ajouter aux favoris</button>
                        </form>
                    {% endif %}
                </div>

                <!-- Emprunt -->
                {% if hasActiveLoan %}
                    <div class="flash-msg flash-info" style="margin-bottom:0;">Ce livre figure déjà dans vos emprunts en cours.</div>
                {% elseif book.availableCopies > 0 %}
                    <form method="post" action="{{ path('app_catalogue_borrow', {id: book.id}) }}" style="margin-top:6px;">
                        <input type="hidden" name="_token" value="{{ csrf_token('borrow-book-' ~ book.id) }}">
                        <div class="field">
                            <label>Date de réservation <span style="color:var(--g400);font-weight:400;">(optionnel)</span></label>
                            <input name="scheduled_for" type="date" min="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <button class="btn" type="submit" style="width:100%;justify-content:center;">Emprunter ce livre</button>
                    </form>
                {% else %}
                    <div class="flash-msg flash-danger" style="margin-bottom:0;">Aucun exemplaire disponible pour le moment.</div>
                {% endif %}
            {% else %}
                <a class="btn" href="{{ path('app_login') }}" style="display:flex;justify-content:center;">Se connecter pour emprunter</a>
            {% endif %}
        </div>

    </div>
</div>

<!-- Avis et notes -->
<div class="card card-body section-gap">
    <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--g400);margin-bottom:14px;">Avis lecteurs</span>
    <h2 style="margin-bottom:20px;">Commentaires & notes</h2>

    {% if app.user %}
        <div class="card" style="background:var(--g50);border-color:var(--g200);padding:20px;margin-bottom:24px;">
            <h3 style="margin-bottom:14px;font-size:.9rem;">{{ userReview ? 'Modifier mon avis' : 'Laisser un avis' }}</h3>
            <form method="post" action="{{ path('app_catalogue_review', {id: book.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('review-book-' ~ book.id) }}">
                <div class="field">
                    <label>Note</label>
                    <select name="rating" required>
                        {% for value in 1..5 %}
                            <option value="{{ value }}" {{ userReview and userReview.rating == value ? 'selected' : '' }}>
                                {% for i in 1..value %}★{% endfor %} ({{ value }}/5)
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label>Commentaire</label>
                    <textarea name="comment" rows="3" required placeholder="Votre avis sur ce livre...">{{ userReview ? userReview.comment : '' }}</textarea>
                </div>
                <button class="btn btn-xs" type="submit">Publier mon avis</button>
            </form>
        </div>
    {% else %}
        <p style="margin-bottom:20px;"><a href="{{ path('app_login') }}" style="color:var(--g800);font-weight:600;text-decoration:underline;">Connectez-vous</a> pour laisser un avis.</p>
    {% endif %}

    <div class="item-list">
        {% for review in reviews %}
            <div class="item-row" style="align-items:flex-start;flex-direction:column;gap:6px;">
                <div style="display:flex;align-items:center;justify-content:space-between;width:100%;">
                    <span class="item-title">{{ review.user.fullName ?: review.user.userIdentifier }}</span>
                    <span class="stars-display">{% for i in 1..5 %}{{ i <= review.rating ? '★' : '☆' }}{% endfor %}</span>
                </div>
                <span class="item-meta">{{ review.createdAt|date('d/m/Y') }}</span>
                <p style="font-size:.88rem;color:var(--g700);line-height:1.65;">{{ review.comment }}</p>
            </div>
        {% else %}
            <div class="empty-state" style="padding:32px 0 8px;">
                <div class="empty-icon">💬</div>
                <h3>Aucun avis publié</h3>
                <p>Soyez le premier à donner votre retour sur ce livre.</p>
            </div>
        {% endfor %}
    </div>
</div>

{% endblock %}
