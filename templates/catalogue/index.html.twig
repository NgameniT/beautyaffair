{% extends 'base.html.twig' %}

{% block title %}Catalogue | BiblioConnect{% endblock %}

{% block body %}

<div class="page-header">
    <span class="eyebrow">Catalogue</span>

</div>

<form method="get" class="filter-bar">
    <div class="filter-group">
        <label>Recherche</label>
        <input type="search" name="q" value="{{ currentQuery }}" placeholder="Titre, auteur, mot-clé...">
    </div>
    <div class="filter-group">
        <label>Catégorie</label>
        <select name="category">
            <option value="">Toutes les catégories</option>
            {% for category in categories %}
                <option value="{{ category }}" {{ currentCategory == category ? 'selected' : '' }}>{{ category }}</option>
            {% endfor %}
        </select>
    </div>
    <div style="display:flex;gap:8px;align-self:flex-end;">
        <button class="btn btn-xs" type="submit" style="padding:9px 20px;">Filtrer</button>
        <a class="btn-outline btn-xs" href="{{ path('app_catalogue') }}" style="padding:9px 20px;">Réinitialiser</a>
    </div>
</form>

{% if books is empty %}
    <div class="empty-state">
        <h3>Aucun résultat</h3>
        <p>Essayez une autre catégorie ou une recherche plus large.</p>
    </div>
{% else %}
    <div class="book-grid">
        {% for book in books %}
            <article class="card book-card" style="overflow:hidden;padding:0;">
                <div class="book-cover theme-{{ book.coverTheme }}">
                    <div class="cover-chips">
                        <span class="cover-chip">{{ book.category }}</span>
                        {% if book.featured %}<span class="cover-chip">★ Sélection</span>{% endif %}
                    </div>
                    <div>
                        <h3>{{ book.title }}</h3>
                        <p class="author">{{ book.author }}</p>
                    </div>
                </div>
                <div class="book-card-body">
                    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;">
                        <span class="badge">{{ book.publishedYear }}</span>
                        <span class="badge">{{ book.pageCount }} p.</span>
                        {% if book.id in activeLoanIds %}
                            <span class="badge badge-blue">Déjà emprunté</span>
                        {% elseif book.availableCopies > 0 %}
                            <span class="badge badge-ok">{{ book.availableCopies }} dispo.</span>
                        {% else %}
                            <span class="badge badge-alert">Indisponible</span>
                        {% endif %}
                    </div>
                    <p style="font-size:.8rem;margin-bottom:14px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{{ book.summary|slice(0,140) ~ '...' }}</p>
                    <a class="btn-outline btn-xs" href="{{ path('app_catalogue_show', {id: book.id}) }}" style="text-decoration:none;">Voir le détail</a>
                </div>
            </article>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}

