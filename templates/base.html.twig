<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}BiblioConnect{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════
   DESIGN SYSTEM — BiblioConnect
   Palette : blanc & gris, moderne, épuré
═══════════════════════════════════════════════ */
:root {
    --white:    #fffdf8;
    --g50:      #f6efe3;
    --g100:     #eee2cf;
    --g200:     #dfccb1;
    --g300:     #cfb895;
    --g400:     #b69873;
    --g500:     #9a7754;
    --g600:     #7f5f41;
    --g700:     #6d4f34;
    --g800:     #5b412b;
    --g900:     #4a3422;
    --red:      #8f3f2f;
    --text-muted: #8a7258;
    --shadow-xs: 0 1px 2px rgba(0,0,0,.05);
    --shadow-sm: 0 1px 4px rgba(0,0,0,.07), 0 0 1px rgba(0,0,0,.04);
    --shadow:    0 4px 20px rgba(0,0,0,.08), 0 1px 4px rgba(0,0,0,.04);
    --r:         12px;
    --r-sm:      8px;
    --r-xs:      6px;
    --ease:      .18s ease;
}

*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: var(--g50);
    color: var(--g800);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
}

/* ─── TYPOGRAPHIE ─── */
h1,h2,h3,h4,h5 { color: var(--g900); font-weight: 700; letter-spacing: -.4px; line-height: 1.25; }
h1 { font-size: clamp(1.75rem, 3.5vw, 2.6rem); }
h2 { font-size: clamp(1.25rem, 2.5vw, 1.7rem); }
h3 { font-size: 1.05rem; }
p  { color: var(--g600); font-size: .9rem; }
a  { color: inherit; }

/* ─── NAVBAR ─── */
.nav-shell {
    position: sticky; top: 0; z-index: 200;
    background: rgba(255,250,240,.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--g200);
}
.nav-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; gap: 8px;
    padding: 0 24px; height: 62px;
}
.nav-brand {
    font-size: 1.15rem; font-weight: 800; color: var(--g900);
    text-decoration: none; letter-spacing: -.6px;
    margin-right: 16px; white-space: nowrap;
}
.nav-brand span { color: var(--g400); font-weight: 400; }
.nav-links { display: flex; gap: 2px; list-style: none; flex: 1; }
.nav-links a {
    font-size: .845rem; font-weight: 500; color: var(--g600);
    text-decoration: none; padding: 6px 11px;
    border-radius: var(--r-xs); transition: var(--ease);
}
.nav-links a:hover { color: var(--g900); background: var(--g100); }
.nav-search {
    flex: 0 1 240px;
}
.nav-search input {
    width: 100%; padding: 7px 16px; border-radius: 999px;
    border: 1px solid var(--g200); background: var(--g100);
    font-size: .83rem; color: var(--g800); outline: none; transition: var(--ease);
    font-family: inherit;
}
.nav-search input::placeholder { color: var(--g400); }
.nav-search input:focus { border-color: var(--g400); background: var(--white); }
.nav-actions { display: flex; gap: 8px; margin-left: 12px; }

/* ─── BOUTONS ─── */
.btn,.btn-outline,.btn-ghost,.btn-ok,.btn-danger-sm {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 20px; border-radius: 999px;
    font-size: .845rem; font-weight: 600; font-family: inherit;
    text-decoration: none; cursor: pointer;
    border: 1px solid transparent; transition: var(--ease);
    white-space: nowrap; line-height: 1;
}
.btn         { background: var(--g900); color: var(--white); border-color: var(--g900); }
.btn:hover   { background: var(--g700); border-color: var(--g700); color: var(--white); }
.btn-outline { background: var(--white); color: var(--g700); border-color: var(--g300); }
.btn-outline:hover { background: var(--g100); color: var(--g900); }
.btn-ghost   { background: transparent; color: var(--g600); }
.btn-ghost:hover { background: var(--g100); color: var(--g900); }
.btn-ok      { background: #efe3cf; color: #5f432b; border-color: #d5ba97; }
.btn-ok:hover{ background: #e3d0b3; }
.btn-danger-sm { background: #f5e3dc; color: #8f3f2f; border-color: #dfb2a5; }
.btn-danger-sm:hover { background: #edd1c7; }
.btn-xs { padding: 5px 13px; font-size: .78rem; }

/* ─── CARTES ─── */
.card {
    background: var(--white); border-radius: var(--r);
    border: 1px solid var(--g200); box-shadow: var(--shadow-sm);
    transition: box-shadow var(--ease);
}
.card:hover { box-shadow: var(--shadow); }
.card-body  { padding: 26px 28px; }
.card-body-sm { padding: 20px 22px; }

/* ─── LAYOUT ─── */
main { flex: 1; padding: 40px 24px; max-width: 1200px; margin: 0 auto; width: 100%; }
.two-col  { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.three-col{ display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
.sidebar-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start; }
.page-header { margin-bottom: 32px; }
.page-header .eyebrow {
    font-size: .72rem; font-weight: 600; letter-spacing: 1.2px;
    text-transform: uppercase; color: var(--g400); display: block; margin-bottom: 8px;
}
.page-header h1 { margin-bottom: 8px; }
.page-header p { font-size: .95rem; max-width: 52ch; }
.flex-between { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
.flex-gap { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

/* ─── BADGES ─── */
.badge {
    display: inline-flex; align-items: center;
    padding: 3px 9px; border-radius: 999px; font-size: .72rem; font-weight: 500;
    background: var(--g100); color: var(--g600);
}
.badge-ok     { background: #efe3cf; color: #5f432b; }
.badge-alert  { background: #f5e3dc; color: #8f3f2f; }
.badge-pending{ background: #f3e6d3; color: #7b5a37; }
.badge-blue   { background: #e8ddcd; color: #6d4f34; }

/* ─── ALERTES FLASH ─── */
.flash-msg {
    padding: 12px 18px; border-radius: var(--r-sm); font-size: .875rem;
    border: 1px solid; margin-bottom: 14px;
}
.flash-success { background: #efe3cf; color: #5f432b; border-color: #d5ba97; }
.flash-danger  { background: #f5e3dc; color: #8f3f2f; border-color: #dfb2a5; }
.flash-warning { background: #f3e6d3; color: #7b5a37; border-color: #d9c1a0; }
.flash-info    { background: #eee3d2; color: #6d4f34; border-color: #d6bf9f; }

/* ─── FORMULAIRES ─── */
.field { margin-bottom: 18px; }
.field label {
    display: block; font-size: .82rem; font-weight: 600;
    color: var(--g700); margin-bottom: 6px;
}
.field input,.field textarea,.field select {
    width: 100%; padding: 10px 14px;
    border: 1px solid var(--g300); border-radius: var(--r-sm);
    font-size: .9rem; color: var(--g800); background: var(--white);
    outline: none; transition: var(--ease); font-family: inherit;
}
.field input:focus,.field textarea:focus,.field select:focus {
    border-color: var(--g600); box-shadow: 0 0 0 3px rgba(107,114,128,.1);
}
.field-error { font-size: .78rem; color: #b91c1c; margin-top: 4px; }
.form-check  { display: flex; align-items: center; gap: 10px; }
.form-check input[type=checkbox]{ width: 16px; height: 16px; flex-shrink: 0; cursor: pointer; }
.form-check label { margin: 0; font-size: .875rem; color: var(--g600); cursor: pointer; }

/* ─── TABLEAU ─── */
.table-wrap { overflow-x: auto; }
.data-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
.data-table thead th {
    text-align: left; padding: 10px 16px;
    font-size: .72rem; font-weight: 600; letter-spacing: .6px;
    text-transform: uppercase; color: var(--g500);
    border-bottom: 1px solid var(--g200); background: var(--g50);
}
.data-table td {
    padding: 13px 16px; border-bottom: 1px solid var(--g100);
    color: var(--g700); vertical-align: middle;
}
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: var(--g50); }

/* ─── STATS ─── */
.stats-row { display: grid; grid-template-columns: repeat(auto-fill,minmax(150px,1fr)); gap: 16px; }
.stat-card {
    background: var(--white); border: 1px solid var(--g200);
    border-radius: var(--r); padding: 20px 24px;
}
.stat-card strong { font-size: 2rem; font-weight: 800; color: var(--g900); display: block; line-height: 1; }
.stat-card p { font-size: .8rem; color: var(--g500); margin-top: 4px; }

/* ─── COUVERTURES DE LIVRES ─── */
.book-cover {
    border-radius: var(--r) var(--r) 0 0;
    padding: 22px 20px; min-height: 160px;
    display: flex; flex-direction: column; justify-content: space-between;
    position: relative;
}
.book-cover h3 { color: #fff; font-size: .95rem; margin-bottom: 2px; line-height: 1.3; }
.book-cover .author { color: rgba(255,255,255,.75); font-size: .78rem; }
.book-cover .cover-chips { display: flex; gap: 6px; flex-wrap: wrap; }
.cover-chip {
    background: rgba(255,255,255,.18); color: #fff;
    padding: 2px 9px; border-radius: 999px; font-size: .7rem; font-weight: 500;
}

.theme-yellow { background: linear-gradient(135deg,#f59e0b,#b45309); }
.theme-dark   { background: linear-gradient(135deg,#374151,#111827); }
.theme-red    { background: linear-gradient(135deg,#f87171,#b91c1c); }
.theme-purple { background: linear-gradient(135deg,#a78bfa,#6d28d9); }
.theme-blue   { background: linear-gradient(135deg,#60a5fa,#1d4ed8); }
.theme-green  { background: linear-gradient(135deg,#4ade80,#15803d); }
.theme-teal   { background: linear-gradient(135deg,#2dd4bf,#0d9488); }
.theme-orange { background: linear-gradient(135deg,#fb923c,#c2410c); }

/* ─── GRILLE CATALOGUE ─── */
.book-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(230px,1fr)); gap: 20px; }
.book-card { transition: transform var(--ease); }
.book-card:hover { transform: translateY(-3px); }
.book-card-body { padding: 16px 18px; }
.book-card-body h3 { font-size: .93rem; margin-bottom: 4px; }

/* ─── LISTE ITEMS (emprunts, favoris) ─── */
.item-list { display: flex; flex-direction: column; gap: 0; }
.item-row {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 15px 0; border-bottom: 1px solid var(--g100);
}
.item-row:last-child { border-bottom: none; padding-bottom: 0; }
.item-row .item-title { font-size: .9rem; font-weight: 600; color: var(--g800); display: block; margin-bottom: 2px; }
.item-row .item-meta  { font-size: .8rem; color: var(--g500); }

/* ─── BARRE FILTRES ─── */
.filter-bar {
    display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;
    background: var(--white); border: 1px solid var(--g200);
    border-radius: var(--r); padding: 18px 22px; margin-bottom: 28px;
}
.filter-group { display: flex; flex-direction: column; gap: 5px; flex: 1; min-width: 160px; }
.filter-group label { font-size: .78rem; font-weight: 600; color: var(--g500); text-transform: uppercase; letter-spacing: .5px; }
.filter-group input, .filter-group select {
    padding: 8px 12px; border: 1px solid var(--g200); border-radius: var(--r-sm);
    font-size: .875rem; color: var(--g800); background: var(--g50); outline: none; font-family: inherit; transition: var(--ease);
}
.filter-group input:focus, .filter-group select:focus { border-color: var(--g400); background: var(--white); }

/* ─── EMPTY STATE ─── */
.empty-state {
    text-align: center; padding: 48px 24px; color: var(--g400);
}
.empty-state .empty-icon { font-size: 2.4rem; margin-bottom: 12px; opacity: .5; }
.empty-state h3 { color: var(--g500); font-size: 1rem; margin-bottom: 6px; }
.empty-state p { font-size: .85rem; }

/* ─── SECTION DIVIDER ─── */
.section-gap { margin-top: 28px; }

/* ─── REVIEW STARS ─── */
.stars-display { color: #9a7754; font-size: .9rem; }

/* ─── BACK-OFFICE SIDEBAR NAV ─── */
.bo-layout { display: grid; grid-template-columns: 220px 1fr; gap: 0; min-height: calc(100vh - 62px - 80px); }
.bo-sidebar {
    background: var(--white); border-right: 1px solid var(--g200);
    padding: 28px 16px;
}
.bo-sidebar .sidebar-label {
    font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    color: var(--g400); padding: 0 12px; margin-bottom: 6px; display: block;
}
.bo-sidebar a {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: var(--r-xs);
    font-size: .865rem; font-weight: 500; color: var(--g600);
    text-decoration: none; transition: var(--ease);
}
.bo-sidebar a:hover { background: var(--g100); color: var(--g900); }
.bo-sidebar a.active { background: var(--g900); color: var(--white); }
.bo-content { padding: 36px; }

/* ─── FOOTER ─── */
footer {
    background: var(--white); border-top: 1px solid var(--g200);
    padding: 24px; text-align: center; margin-top: auto;
}
footer p { font-size: .8rem; color: var(--g400); }
footer .foot-links { margin-top: 8px; display: flex; gap: 4px; justify-content: center; flex-wrap: wrap; }
footer .foot-links a {
    font-size: .78rem; color: var(--g400); text-decoration: none;
    padding: 2px 8px; border-radius: 999px; transition: var(--ease);
}
footer .foot-links a:hover { color: var(--g700); background: var(--g100); }

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
    .two-col, .sidebar-layout { grid-template-columns: 1fr; }
    .three-col { grid-template-columns: 1fr 1fr; }
    .bo-layout { grid-template-columns: 1fr; }
    .bo-sidebar { display: none; }
    .bo-content { padding: 20px; }
}
@media (max-width: 600px) {
    .nav-search { display: none; }
    .nav-links  { display: none; }
    main { padding: 24px 16px; }
    .three-col { grid-template-columns: 1fr; }
    .book-grid { grid-template-columns: 1fr 1fr; }
    .filter-bar { flex-direction: column; }
}
@media (max-width: 400px) {
    .book-grid { grid-template-columns: 1fr; }
}
</style>
{% block stylesheets %}{% endblock %}
</head>
<body>

<!-- ═══════ NAVBAR ═══════ -->
<div class="nav-shell">
    <nav class="nav-inner">
        <a class="nav-brand" href="{{ path('app_home') }}">Biblio<span>Connect</span></a>

        <ul class="nav-links">
            <li><a href="{{ path('app_home') }}">Accueil</a></li>
            <li><a href="{{ path('app_catalogue') }}">Catalogue</a></li>
            {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                    <li><a href="{{ path('app_admin_dashboard') }}">Admin</a></li>
                {% elseif is_granted('ROLE_LIBRARIAN') %}
                    <li><a href="{{ path('app_librarian_dashboard') }}">Bibliothécaire</a></li>
                {% else %}
                    <li><a href="{{ path('app_dashboard') }}">Mon espace</a></li>
                {% endif %}
            {% endif %}
        </ul>

        <div class="nav-search">
            <form method="get" action="{{ path('app_catalogue') }}">
                <input type="search" name="q" placeholder="Rechercher un livre...">
            </form>
        </div>

        <div class="nav-actions">
            {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_dashboard') }}" class="btn-outline btn-xs">Admin</a>
                {% elseif is_granted('ROLE_LIBRARIAN') %}
                    <a href="{{ path('app_librarian_dashboard') }}" class="btn-outline btn-xs">Bibliothécaire</a>
                {% else %}
                    <a href="{{ path('app_dashboard') }}" class="btn-outline btn-xs">Mon espace</a>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="btn btn-xs">Déconnexion</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn-outline btn-xs">Connexion</a>
                <a href="{{ path('app_register') }}" class="btn btn-xs">Inscription</a>
            {% endif %}
        </div>
    </nav>
</div>

<!-- ═══════ MAIN ═══════ -->
<main>
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-msg flash-{{ label == 'error' ? 'danger' : (label == 'warning' ? 'warning' : (label == 'success' ? 'success' : 'info')) }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<!-- ═══════ FOOTER ═══════ -->
<footer>
    <p>© {{ "now"|date("Y") }} BiblioConnect · La bibliothèque numérique moderne</p>
    <div class="foot-links">
        <a href="{{ path('app_home') }}">Mentions légales</a>
        <a href="{{ path('app_home') }}">Confidentialité</a>
        <a href="{{ path('app_home') }}">Contact</a>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>

