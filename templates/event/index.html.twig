{% extends 'base.html.twig' %}

{% block title %}Evenements | BiblioConnect{% endblock %}

{% block body %}
<section class="section-head">
    <div>
        <span class="eyebrow">Agenda</span>
        <h1 style="font-size: clamp(2.5rem, 6vw, 4.4rem);">Rencontres, ateliers et formats collectifs pour activer la bibliotheque.</h1>
        <p>Inscrivez-vous aux prochains rendez-vous directement depuis la plateforme.</p>
    </div>
</section>

<div class="event-grid">
    {% for event in events %}
        {% set registrations = registrationCounts[event.id] ?? 0 %}
        {% set isRegistered = event.id in registeredEventIds %}
        <article class="event-card">
            <div class="event-banner theme-{{ event.theme }}">
                <div class="chip-row">
                    <span class="chip" style="background: rgba(255,255,255,0.16); color: #fff;">{{ event.startsAt|date('d/m/Y') }}</span>
                    <span class="chip" style="background: rgba(255,255,255,0.16); color: #fff;">{{ event.startsAt|date('H\\hi') }}</span>
                </div>
                <div>
                    <h3>{{ event.title }}</h3>
                    <p style="color: rgba(255,255,255,0.88);">{{ event.location }}</p>
                </div>
            </div>

            <div class="card-copy">
                <div class="meta-row">
                    <span class="chip">{{ event.speaker }}</span>
                    <span class="chip">{{ registrations }}/{{ event.capacity }} inscrits</span>
                    {% if registrations >= event.capacity %}
                        <span class="status-chip is-alert">Complet</span>
                    {% elseif isRegistered %}
                        <span class="status-chip is-ok">Inscrit</span>
                    {% else %}
                        <span class="status-chip is-muted">Places ouvertes</span>
                    {% endif %}
                </div>

                <p>{{ event.description }}</p>

                {% if app.user %}
                    {% if isRegistered %}
                        <span class="button-secondary">Vous etes deja inscrit</span>
                    {% elseif registrations >= event.capacity %}
                        <span class="button-secondary">Liste complete</span>
                    {% else %}
                        <form method="post" action="{{ path('app_events_register', {id: event.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('register-event-' ~ event.id) }}">
                            <button class="button" type="submit">Reserver ma place</button>
                        </form>
                    {% endif %}
                {% else %}
                    <a class="button" href="{{ path('app_login') }}">Connexion pour s'inscrire</a>
                {% endif %}
            </div>
        </article>
    {% endfor %}
</div>
{% endblock %}
