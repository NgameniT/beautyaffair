{% extends 'base.html.twig' %}
{% block title %}Mes Favoris · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.page-header {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 100%);
    padding: 64px 0 48px; text-align: center; position: relative; overflow: hidden;
}
.page-header::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% 100%,rgba(196,147,63,.15) 0%,transparent 65%); }
.page-header .container { position:relative; z-index:1; }
.page-header .eyebrow { font-size:.68rem; letter-spacing:3px; text-transform:uppercase; color:var(--beige); display:block; margin-bottom:14px; }
.page-header h1 { color:var(--cream); margin-bottom:10px; }

.product-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
.product-card { background:var(--white); border:1px solid var(--beige); border-radius:8px; overflow:hidden; transition:all .3s ease; display:flex; flex-direction:column; }
.product-card:hover { border-color:var(--brown-light); box-shadow:0 10px 32px rgba(125,78,45,.1); transform:translateY(-4px); }
.product-img { height:200px; background:var(--cream-soft); display:flex; align-items:center; justify-content:center; font-size:4rem; border-bottom:1px solid var(--beige); flex-shrink:0; }
.product-body { padding:18px 20px; flex:1; }
.product-body h4 { font-family:'Cormorant Garamond',serif; font-size:1.1rem; color:var(--brown-dark); margin-bottom:6px; }
.product-body p { font-size:.84rem; color:var(--text-soft); }
.product-footer { display:flex; justify-content:space-between; align-items:center; gap:8px; padding:12px 20px; border-top:1px solid var(--beige); flex-shrink:0; }
.product-price { color:var(--brown); font-weight:600; }

.fav-btn {
    display:inline-flex; align-items:center; gap:6px;
    padding:7px 14px; border-radius:4px; cursor:pointer;
    font-size:.72rem; font-weight:500; letter-spacing:1.5px; text-transform:uppercase;
    font-family:'Jost',sans-serif; border:1px solid; transition:var(--ease);
}
.fav-btn-remove { background:rgba(220,38,38,.07); color:#991b1b; border-color:rgba(220,38,38,.25); }
.fav-btn-remove:hover { background:rgba(220,38,38,.15); }
.fav-btn-cart { background:var(--brown); color:var(--white); border-color:var(--brown); }
.fav-btn-cart:hover { background:var(--brown-dark); }

@media(max-width:900px){ .product-grid{grid-template-columns:1fr 1fr;} }
@media(max-width:600px){ .product-grid{grid-template-columns:1fr;} }
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container">
        <span class="eyebrow">✦ Ma liste</span>
        <h1>Mes Favoris</h1>
        {% if produits is not empty %}
            <p style="color:var(--beige-dark);margin-top:8px;">{{ produits|length }} article{{ produits|length > 1 ? 's' : '' }} sauvegardé{{ produits|length > 1 ? 's' : '' }}</p>
        {% endif %}
    </div>
</div>

<div style="padding:64px 0;">
    <div class="container">

        {% if produits is empty %}
            <div style="text-align:center;padding:80px 24px;">
                <div style="font-size:4rem;margin-bottom:20px;">🤍</div>
                <h2 style="color:var(--brown-dark);margin-bottom:12px;">Aucun favori pour le moment</h2>
                <p style="margin-bottom:32px;">Parcourez notre boutique et cliquez sur ♥ pour sauvegarder vos coups de cœur.</p>
                <a href="{{ path('app_boutique') }}" class="btn">Découvrir la boutique</a>
            </div>
        {% else %}
            <div class="product-grid">
                {% for produit in produits %}
                <div class="product-card">
                    <a href="{{ path('app_boutique_show', {id: produit.id}) }}" style="display:block;">
                    {% if produit.image %}
                        <div class="product-img" style="padding:0;">
                            <img src="/uploads/produits/{{ produit.image }}" alt="{{ produit.nom }}"
                                 style="width:100%;height:100%;object-fit:cover;">
                        </div>
                    {% else %}
                        <div class="product-img">{{ produit.categorie.icone ?? '🛍️' }}</div>
                    {% endif %}
                    </a>
                    <div class="product-body">
                        <h4>{{ produit.nom }}</h4>
                        {% if produit.description %}
                            <p>{{ produit.description|slice(0,80) }}{% if produit.description|length > 80 %}…{% endif %}</p>
                        {% endif %}
                    </div>
                    <div class="product-footer">
                        <span class="product-price">{{ produit.prix|number_format(0,',',' ') }} FCFA</span>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;">
                            {# Retirer des favoris #}
                            <form method="post" action="{{ path('app_favoris_toggle', {id: produit.id}) }}" style="display:inline;">
                                <button type="submit" class="fav-btn fav-btn-remove" title="Retirer des favoris">
                                    <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                    Retirer
                                </button>
                            </form>
                            {# Ajouter au panier #}
                            {% if produit.stock > 0 %}
                            <form method="post" action="{{ path('app_cart_add', {id: produit.id}) }}" style="display:inline;">
                                <input type="hidden" name="qty" value="1">
                                <button type="submit" class="fav-btn fav-btn-cart">
                                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                                    Panier
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>

            <div style="text-align:center;margin-top:40px;">
                <a href="{{ path('app_boutique') }}" class="btn-outline">← Continuer mes achats</a>
            </div>
        {% endif %}

    </div>
</div>

{% endblock %}
