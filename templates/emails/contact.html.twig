<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"><title>Message contact</title></head>
<body style="margin:0;padding:0;background:#fdf8f3;font-family:'Segoe UI',Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="background:#fdf8f3;padding:32px 0;">
<tr><td align="center">
<table width="580" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:10px;overflow:hidden;box-shadow:0 2px 16px rgba(125,78,45,.1);">

    <!-- Header -->
    <tr><td style="background:linear-gradient(135deg,#3d1a08 0%,#7d4e2d 100%);padding:32px 40px;text-align:center;">
        <div style="font-size:.7rem;letter-spacing:3px;text-transform:uppercase;color:#d4c0a5;margin-bottom:10px;">BeautyAffair · Cotonou</div>
        <h1 style="color:#fdf8f3;margin:0;font-size:1.4rem;font-weight:300;letter-spacing:1px;">Nouveau message</h1>
    </td></tr>

    <!-- Body -->
    <tr><td style="padding:36px 40px;">
        <p style="color:#7d4e2d;font-size:.75rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:20px;">Détails du message</p>

        <table width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #f0e8da;border-radius:8px;overflow:hidden;margin-bottom:24px;">
            <tr style="background:#fdf8f3;">
                <td style="padding:12px 16px;font-size:.8rem;color:#9b7a55;font-weight:600;width:130px;">De</td>
                <td style="padding:12px 16px;font-size:.9rem;color:#3d1a08;font-weight:600;">{{ nom }}</td>
            </tr>
            <tr style="border-top:1px solid #f0e8da;">
                <td style="padding:12px 16px;font-size:.8rem;color:#9b7a55;font-weight:600;">Email</td>
                <td style="padding:12px 16px;font-size:.9rem;color:#3d1a08;">
                    <a href="mailto:{{ email }}" style="color:#7d4e2d;text-decoration:none;">{{ email }}</a>
                </td>
            </tr>
            {% if telephone %}
            <tr style="border-top:1px solid #f0e8da;">
                <td style="padding:12px 16px;font-size:.8rem;color:#9b7a55;font-weight:600;">Téléphone</td>
                <td style="padding:12px 16px;font-size:.9rem;color:#3d1a08;">{{ telephone }}</td>
            </tr>
            {% endif %}
            <tr style="border-top:1px solid #f0e8da;">
                <td style="padding:12px 16px;font-size:.8rem;color:#9b7a55;font-weight:600;">Sujet</td>
                <td style="padding:12px 16px;font-size:.9rem;color:#3d1a08;">{{ sujet }}</td>
            </tr>
        </table>

        <p style="color:#7d4e2d;font-size:.75rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;">Message</p>
        <div style="background:#fdf8f3;border:1px solid #f0e8da;border-radius:8px;padding:20px 24px;font-size:.95rem;color:#5c3317;line-height:1.8;white-space:pre-wrap;">{{ message }}</div>

        <div style="margin-top:28px;text-align:center;">
            <a href="mailto:{{ email }}" style="display:inline-block;background:#7d4e2d;color:#fff;text-decoration:none;padding:12px 28px;border-radius:6px;font-size:.82rem;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;">
                Répondre à {{ nom }}
            </a>
        </div>
    </td></tr>

    <!-- Footer -->
    <tr><td style="padding:20px 40px;border-top:1px solid #f0e8da;text-align:center;">
        <p style="color:#b8a090;font-size:.75rem;margin:0;">BeautyAffair · Cotonou, Bénin</p>
    </td></tr>

</table>
</td></tr>
</table>
</body>
</html>
