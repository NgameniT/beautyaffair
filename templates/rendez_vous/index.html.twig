{% extends 'base.html.twig' %}
{% block title %}Mes rendez-vous · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.page-header {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 100%);
    padding: 64px 0 48px; text-align: center;
    position: relative; overflow: hidden;
}
.page-header::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 100%, rgba(196,147,63,.15) 0%, transparent 65%);
}
.page-header .container { position: relative; z-index: 1; }
.page-header h1 { color: var(--cream); margin-bottom: 10px; }
.page-header p  { color: var(--beige-dark); }

.section { padding: 60px 0; }

.rdv-card {
    background: var(--white);
    border: 1px solid var(--beige);
    border-radius: 10px; padding: 24px 28px;
    display: flex; align-items: flex-start; gap: 20px;
    margin-bottom: 16px;
    transition: box-shadow .2s;
}
.rdv-card:hover { box-shadow: 0 4px 20px rgba(125,78,45,.1); }

.rdv-date-block {
    background: var(--cream-soft);
    border: 1px solid var(--beige-dark);
    border-radius: 8px; padding: 10px 16px;
    text-align: center; min-width: 72px; flex-shrink: 0;
}
.rdv-date-block .day   { font-size: 1.8rem; font-weight: 300; color: var(--brown); font-family: 'Cormorant Garamond', serif; line-height: 1; }
.rdv-date-block .month { font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-top: 4px; }
.rdv-date-block .heure { font-size: .8rem; color: var(--brown-dark); font-weight: 500; margin-top: 6px; }

.rdv-info { flex: 1; }
.rdv-info h4 { color: var(--brown-dark); font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; margin-bottom: 4px; }
.rdv-info .cat { font-size: .78rem; color: var(--text-muted); margin-bottom: 8px; letter-spacing: .5px; }
.rdv-info .prix { font-size: .9rem; color: var(--brown); font-weight: 500; }
.rdv-info .duree { font-size: .82rem; color: var(--text-muted); margin-left: 12px; }
.rdv-info .notes { margin-top: 8px; font-size: .85rem; color: var(--text-soft); font-style: italic; }

.rdv-actions { display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; align-items: flex-end; }

.statut-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 12px; border-radius: 20px;
    font-size: .72rem; font-weight: 500; letter-spacing: .5px;
    text-transform: uppercase;
}
.statut-en_attente { background: rgba(196,147,63,.12); color: #92400e; border: 1px solid rgba(196,147,63,.3); }
.statut-confirme   { background: rgba(34,197,94,.1);  color: #166534; border: 1px solid rgba(34,197,94,.3); }
.statut-annule     { background: rgba(239,68,68,.1);  color: #991b1b; border: 1px solid rgba(239,68,68,.3); }
.statut-termine    { background: rgba(125,78,45,.1);  color: var(--brown-dark); border: 1px solid var(--beige-dark); }

.empty-state { text-align: center; padding: 80px 24px; }
.empty-state .ico { font-size: 4rem; margin-bottom: 20px; }
.empty-state h3 { color: var(--brown-dark); margin-bottom: 12px; }
.empty-state p  { color: var(--text-soft); margin-bottom: 32px; }

.cancel-form button {
    background: none; border: none; cursor: pointer;
    font-size: .75rem; color: #b91c1c;
    padding: 4px 8px; border-radius: 4px;
    font-family: 'Jost', sans-serif; letter-spacing: .5px;
    transition: background .2s;
}
.cancel-form button:hover { background: rgba(185,28,28,.07); }
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container">
        <span style="font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--beige);display:block;margin-bottom:12px;">✦ Mon espace</span>
        <h1>Mes rendez-vous</h1>
        <p style="color:var(--beige-dark);">Bonjour {{ app.user.prenom }}, voici l'historique de vos réservations.</p>
    </div>
</div>

<section class="section">
    <div class="container">

        <div class="flex-between" style="margin-bottom:32px;">
            <h2 style="color:var(--brown-dark);">
                {{ rdvs|length }} rendez-vous
            </h2>
            <a href="{{ path('app_rdv_new') }}" class="btn">+ Nouveau rendez-vous</a>
        </div>

        {% if rdvs is empty %}
            <div class="empty-state">
                <div class="ico" style="font-size:0;display:flex;justify-content:center;margin-bottom:20px;">
                    <div style="width:72px;height:72px;background:rgba(125,78,45,.09);border-radius:50%;border:1px solid rgba(125,78,45,.2);display:flex;align-items:center;justify-content:center;">
                        <svg width="34" height="34" fill="none" viewBox="0 0 24 24" stroke="var(--brown)" stroke-width="1.4" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                </div>
                <h3>Aucun rendez-vous pour le moment</h3>
                <p>Réservez votre première prestation en quelques clics.</p>
                <a href="{{ path('app_rdv_new') }}" class="btn">Prendre rendez-vous</a>
            </div>
        {% else %}
            {% for rdv in rdvs %}
            <div class="rdv-card">

                <div class="rdv-date-block">
                    <div class="day">{{ rdv.dateHeure|date('d') }}</div>
                    <div class="month">{{ rdv.dateHeure|date('M Y') }}</div>
                    <div class="heure">{{ rdv.dateHeure|date('H:i') }}</div>
                </div>

                <div class="rdv-info">
                    <h4>{{ rdv.prestation.nom }}</h4>
                    <div class="cat">{{ rdv.prestation.categorie.nom }}</div>
                    <div>
                        <span class="prix">{{ rdv.prestation.prix|number_format(0, ',', ' ') }} FCFA</span>
                        <span class="duree">· {{ rdv.prestation.duree }} min</span>
                    </div>
                    {% if rdv.notes %}
                        <div class="notes">"{{ rdv.notes }}"</div>
                    {% endif %}
                </div>

                <div class="rdv-actions">
                    <span class="statut-badge statut-{{ rdv.statut }}">
                        {% if rdv.statut == 'en_attente' %}
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> En attente
                        {% elseif rdv.statut == 'confirme' %}
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Confirmé
                        {% elseif rdv.statut == 'annule' %}
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Annulé
                        {% else %}
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Terminé
                        {% endif %}
                    </span>

                    {% if rdv.statut in ['en_attente', 'confirme'] %}
                        <form class="cancel-form" method="post" action="{{ path('app_rdv_cancel', {id: rdv.id}) }}"
                              onsubmit="return confirm('Confirmer l\'annulation de ce rendez-vous ?')">
                            <button type="submit">Annuler le RDV</button>
                        </form>
                    {% endif %}
                </div>

            </div>
            {% endfor %}
        {% endif %}

    </div>
</section>

{% endblock %}
