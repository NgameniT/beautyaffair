{% extends 'base.html.twig' %}
{% block title %}Rendez-vous · BeautyAffair{% endblock %}

{% block body %}
<div style="background:linear-gradient(135deg,var(--brown-dark) 0%,#5C2F0E 100%);padding:72px 0 56px;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 100%,rgba(196,147,63,.15) 0%,transparent 65%);"></div>
    <div class="container" style="position:relative;z-index:1;">
        <span style="font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--beige);display:block;margin-bottom:14px;">✦ Réservation en ligne</span>
        <h1 style="color:var(--cream);margin-bottom:14px;">Prenez rendez-vous</h1>
        <p style="color:var(--beige-dark);max-width:48ch;margin:0 auto;">Connectez-vous pour réserver votre créneau en quelques clics. Confirmation sous 24h.</p>
    </div>
</div>

<div style="padding:80px 0;">
    <div class="container" style="max-width:480px;margin:0 auto;text-align:center;">
        <div style="font-size:4rem;margin-bottom:24px;">📅</div>
        <h2 style="color:var(--brown-dark);margin-bottom:16px;">Connectez-vous pour réserver</h2>
        <p style="color:var(--text-soft);margin-bottom:36px;">Pour prendre rendez-vous, vous devez avoir un compte BeautyAffair. C'est gratuit et rapide !</p>
        <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
            <a href="{{ path('app_login') }}" class="btn">Se connecter</a>
            <a href="{{ path('app_register') }}" class="btn-outline">Créer un compte</a>
        </div>
        <p style="margin-top:32px;font-size:.85rem;color:var(--text-muted);">Vous avez déjà un compte ? <a href="{{ path('app_login') }}" style="color:var(--brown);">Connectez-vous ici</a></p>
    </div>
</div>
{% endblock %}
