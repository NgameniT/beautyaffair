{% extends 'base.html.twig' %}
{% block title %}Mon panier · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.page-header {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 100%);
    padding: 52px 0 40px; text-align: center; position: relative; overflow: hidden;
}
.page-header::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% 100%,rgba(196,147,63,.15) 0%,transparent 65%); }
.page-header .container { position:relative; z-index:1; }
.page-header h1 { color:var(--cream); margin-bottom:8px; }
.page-header p  { color:var(--beige-dark); }

.cart-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 28px;
    padding: 48px 0 80px;
    align-items: start;
}

/* ── LIGNES PANIER ── */
.cart-items { display: flex; flex-direction: column; gap: 12px; }
.cart-line {
    background: var(--white); border: 1px solid var(--beige);
    border-radius: 10px; padding: 20px 24px;
    display: flex; align-items: center; gap: 20px;
}
.cart-line-icon {
    width: 60px; height: 60px; flex-shrink: 0;
    background: var(--cream-soft); border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; border: 1px solid var(--beige);
}
.cart-line-info { flex: 1; min-width: 0; }
.cart-line-info .cat { font-size:.68rem; letter-spacing:1.5px; text-transform:uppercase; color:var(--text-muted); }
.cart-line-info h4 { color:var(--brown-dark); font-family:'Cormorant Garamond',serif; font-size:1.1rem; margin:2px 0 6px; }
.cart-line-info .prix-unit { font-size:.85rem; color:var(--text-muted); }

.qty-control { display:flex; align-items:center; gap:0; border:1px solid var(--beige-dark); border-radius:6px; overflow:hidden; }
.qty-btn {
    width:34px; height:34px; border:none; background:var(--cream-soft);
    cursor:pointer; font-size:1.1rem; color:var(--brown-dark);
    transition:var(--ease); display:flex; align-items:center; justify-content:center;
    font-family:'Jost',sans-serif;
}
.qty-btn:hover { background:var(--beige); }
.qty-input {
    width:42px; height:34px; border:none; border-left:1px solid var(--beige-dark);
    border-right:1px solid var(--beige-dark); text-align:center;
    font-size:.9rem; font-family:'Jost',sans-serif; color:var(--text);
    background:var(--white);
}
.qty-input:focus { outline:none; }

.cart-line-total { font-size:1rem; font-weight:600; color:var(--brown); white-space:nowrap; min-width:80px; text-align:right; }
.remove-btn {
    background:none; border:none; cursor:pointer; color:var(--text-muted);
    padding:6px; border-radius:4px; transition:var(--ease);
    flex-shrink:0;
}
.remove-btn:hover { color:#dc2626; background:rgba(220,38,38,.07); }
.remove-btn svg { width:16px; height:16px; }

/* ── RÉSUMÉ ── */
.cart-summary {
    background: var(--white); border: 1px solid var(--beige);
    border-radius: 10px; padding: 28px 24px;
    position: sticky; top: 90px;
}
.cart-summary h3 { color:var(--brown-dark); font-size:1.2rem; margin-bottom:20px; }
.summary-line { display:flex; justify-content:space-between; margin-bottom:12px; font-size:.9rem; }
.summary-line .label { color:var(--text-soft); }
.summary-line .val   { color:var(--text); font-weight:500; }
.summary-total {
    border-top: 2px solid var(--beige);
    padding-top: 14px; margin-top: 6px;
    display:flex; justify-content:space-between;
    font-size:1.1rem; font-weight:600;
}
.summary-total .label { color:var(--brown-dark); }
.summary-total .val   { color:var(--brown); }
.summary-note { font-size:.78rem; color:var(--text-muted); margin:12px 0 20px; line-height:1.5; }

.empty-cart { text-align:center; padding:80px 24px; }
.empty-cart .ico { font-size:4rem; margin-bottom:20px; }
.empty-cart h3 { color:var(--brown-dark); margin-bottom:10px; }

@media (max-width: 900px) {
    .cart-layout { grid-template-columns: 1fr; }
    .cart-summary { position: static; }
}
@media (max-width: 600px) {
    .cart-line { flex-wrap:wrap; }
    .cart-line-icon { display:none; }
}
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container">
        <h1>Mon panier</h1>
        <p style="color:var(--beige-dark);">{{ items|length }} article(s) sélectionné(s)</p>
    </div>
</div>

<div class="container">
    {% if items is empty %}
        <div class="empty-cart">
            <div class="ico">🛒</div>
            <h3>Votre panier est vide</h3>
            <p style="color:var(--text-soft);margin-bottom:28px;">Découvrez nos perruques et bijoux et ajoutez vos favoris.</p>
            <a href="{{ path('app_boutique') }}" class="btn">Aller à la boutique</a>
        </div>
    {% else %}
        <div class="cart-layout">

            <!-- ARTICLES -->
            <div class="cart-items">
                <div style="font-size:.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--text-muted);margin-bottom:4px;">
                    {{ items|length }} article(s) dans votre panier
                </div>

                {% for item in items %}
                {% set p = item.produit %}
                <div class="cart-line">
                    <div class="cart-line-icon" style="{{ p.image ? 'padding:0;overflow:hidden;' : '' }}">
                        {% if p.image %}
                            <img src="/uploads/produits/{{ p.image }}" alt="{{ p.nom }}"
                                 style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
                        {% elseif p.categorie.slug == 'perruques' %}👱‍♀️
                        {% else %}💍{% endif %}
                    </div>
                    <div class="cart-line-info">
                        <div class="cat">{{ p.categorie.nom }}</div>
                        <h4>{{ p.nom }}</h4>
                        <div class="prix-unit">{{ p.prix|number_format(0,',',' ') }} FCFA / unité</div>
                    </div>

                    <!-- Quantité -->
                    <form method="post" action="{{ path('app_cart_update', {id: p.id}) }}">
                        <div class="qty-control">
                            <button type="button" value="{{ item.quantite - 1 }}" class="qty-btn">−</button>
                            <input type="number" name="qty" value="{{ item.quantite }}" min="0" max="99"
                                   class="qty-input" onchange="this.form.submit()">
                            <button type="button" value="{{ item.quantite + 1 }}" class="qty-btn">+</button>
                        </div>
                    </form>

                    <div class="cart-line-total">
                        {{ item.sous_total|number_format(0,',',' ') }} FCFA
                    </div>

                    <!-- Supprimer -->
                    <form method="post" action="{{ path('app_cart_remove', {id: p.id}) }}">
                        <button type="button" class="remove-btn"
                                onclick="if(confirm('Retirer cet article ?')) this.form.submit()">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                        </button>
                    </form>
                </div>
                {% endfor %}

                <div style="margin-top:8px;">
                    <a href="{{ path('app_boutique') }}" style="font-size:.85rem;color:var(--brown);text-decoration:none;">
                        ← Continuer les achats
                    </a>
                </div>
            </div>

            <!-- RÉSUMÉ -->
            <div class="cart-summary">
                <h3>Résumé</h3>
                <div class="summary-line">
                    <span class="label">Sous-total</span>
                    <span class="val">{{ total|number_format(0,',',' ') }} FCFA</span>
                </div>
                <div class="summary-line">
                    <span class="label">Livraison</span>
                    <span class="val" style="color:#16a34a;">Gratuite*</span>
                </div>
                <div class="summary-total">
                    <span class="label">Total</span>
                    <span class="val">{{ total|number_format(0,',',' ') }} FCFA</span>
                </div>
                <p class="summary-note">*Livraison gratuite à Cotonou. Paiement sécurisé via Mobile Money ou carte.</p>

                {% if app.user %}
                    <a href="{{ path('app_cart_order') }}" class="btn" style="width:100%;justify-content:center;padding:14px;">
                        Passer la commande →
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn" style="width:100%;justify-content:center;padding:14px;">
                        Se connecter pour commander
                    </a>
                    <p style="font-size:.78rem;color:var(--text-muted);text-align:center;margin-top:10px;">
                        Pas encore inscrit ? <a href="{{ path('app_register') }}" style="color:var(--brown);">Créer un compte</a>
                    </p>
                {% endif %}
            </div>

        </div>
    {% endif %}
</div>

{% endblock %}
