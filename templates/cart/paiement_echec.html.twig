{% extends 'base.html.twig' %}
{% block title %}Paiement non complété · BeautyAffair{% endblock %}

{% block body %}
<div style="max-width:500px;margin:80px auto;padding:0 24px;text-align:center;">

    <div style="font-size:3.5rem;margin-bottom:20px;">⚠️</div>
    <h1 style="font-size:1.8rem;color:var(--brown-dark);margin-bottom:12px;">Paiement non complété</h1>
    <p style="margin-bottom:32px;">
        Votre commande <strong>#{{ commande.id }}</strong> a été enregistrée mais le paiement n'a pas pu être confirmé.<br>
        Vous pouvez réessayer ou nous contacter.
    </p>

    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <form method="post" action="{{ path('app_paiement_simuler', {id: commande.id}) }}">
            <button type="submit" class="btn">Réessayer le paiement</button>
        </form>
        <a href="{{ path('app_contact') }}" class="btn-outline">Nous contacter</a>
    </div>

    <p style="margin-top:32px;font-size:.82rem;color:var(--text-muted);">
        Référence commande : <strong>#{{ commande.id }}</strong><br>
        Montant : <strong>{{ commande.total|number_format(0,',',' ') }} FCFA</strong>
    </p>

</div>
{% endblock %}
