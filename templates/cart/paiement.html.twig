{% extends 'base.html.twig' %}
{% block title %}Paiement · BeautyAffair{% endblock %}

{% block body %}
<div style="max-width:560px;margin:60px auto;padding:0 24px;">

    <div style="text-align:center;margin-bottom:36px;">
        <span style="font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--brown);display:block;margin-bottom:12px;">✦ Finaliser la commande</span>
        <h1 style="font-size:2rem;color:var(--brown-dark);margin-bottom:8px;">Paiement</h1>
        <p>Commande <strong>#{{ commande.id }}</strong> — Total : <strong>{{ commande.total|number_format(0,',',' ') }} FCFA</strong></p>
    </div>

    <div style="background:var(--white);border:1px solid var(--beige);border-radius:10px;overflow:hidden;margin-bottom:24px;">

        <div style="padding:20px 24px;background:var(--cream-soft);border-bottom:1px solid var(--beige);">
            <h2 style="font-size:1rem;color:var(--brown-dark);">Choisissez votre mode de paiement</h2>
        </div>

        <div style="padding:24px;display:flex;flex-direction:column;gap:14px;">

            {# MTN Mobile Money #}
            <div style="display:flex;align-items:center;gap:16px;padding:16px;border:2px solid var(--beige);border-radius:8px;cursor:pointer;" onclick="selectMode('mtn')" id="opt-mtn">
                <div style="width:44px;height:44px;background:#FFCC00;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">📱</div>
                <div>
                    <div style="font-weight:600;color:var(--brown-dark);font-size:.95rem;">MTN Mobile Money</div>
                    <div style="font-size:.82rem;color:var(--text-muted);">Payez directement depuis votre compte MTN MoMo</div>
                </div>
            </div>

            {# Moov Money #}
            <div style="display:flex;align-items:center;gap:16px;padding:16px;border:2px solid var(--beige);border-radius:8px;cursor:pointer;" onclick="selectMode('moov')" id="opt-moov">
                <div style="width:44px;height:44px;background:#0099CC;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">📲</div>
                <div>
                    <div style="font-weight:600;color:var(--brown-dark);font-size:.95rem;">Moov Money</div>
                    <div style="font-size:.82rem;color:var(--text-muted);">Payez depuis votre compte Moov Money</div>
                </div>
            </div>

            {# Carte bancaire #}
            <div style="display:flex;align-items:center;gap:16px;padding:16px;border:2px solid var(--beige);border-radius:8px;cursor:pointer;" onclick="selectMode('card')" id="opt-card">
                <div style="width:44px;height:44px;background:#5469D4;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">💳</div>
                <div>
                    <div style="font-weight:600;color:var(--brown-dark);font-size:.95rem;">Carte bancaire</div>
                    <div style="font-size:.82rem;color:var(--text-muted);">Visa, Mastercard — paiement sécurisé PayDunya</div>
                </div>
            </div>

        </div>
    </div>

    {# Flashes (erreur PayDunya éventuelle) #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div style="padding:14px 18px;border-radius:8px;margin-bottom:16px;font-size:.85rem;border:1px solid;
                {% if label == 'danger' %}background:rgba(220,38,38,.07);color:#991b1b;border-color:rgba(220,38,38,.25);
                {% else %}background:rgba(22,163,74,.07);color:#166534;border-color:rgba(22,163,74,.25);{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Bouton simulation (test) #}
    <form method="post" action="{{ path('app_paiement_simuler', {id: commande.id}) }}">
        <button type="submit" style="width:100%;padding:14px;background:var(--brown);color:var(--white);border:none;border-radius:8px;font-family:'Jost',sans-serif;font-size:.9rem;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:var(--ease);"
                onmouseover="this.style.background='var(--brown-dark)'" onmouseout="this.style.background='var(--brown)'">
            ✓ Simuler le paiement — {{ commande.total|number_format(0,',',' ') }} FCFA
        </button>
    </form>

    <div style="text-align:center;margin-top:16px;">
        <a href="{{ path('app_boutique') }}" style="font-size:.82rem;color:var(--text-muted);">← Continuer mes achats</a>
    </div>

</div>

<script>
function selectMode(mode) {
    ['mtn','moov','card'].forEach(function(m) {
        var el = document.getElementById('opt-' + m);
        el.style.borderColor = m === mode ? 'var(--brown)' : 'var(--beige)';
        el.style.background  = m === mode ? 'rgba(125,78,45,.04)' : '';
    });
}
</script>
{% endblock %}
