{% extends 'base.html.twig' %}
{% block title %}{{ produit.nom }} · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.breadcrumb {
    padding: 16px 0;
    font-size: .8rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--beige);
    margin-bottom: 0;
}
.breadcrumb a { color: var(--brown); text-decoration: none; }
.breadcrumb a:hover { text-decoration: underline; }
.breadcrumb span { margin: 0 8px; color: var(--beige-dark); }

.produit-wrap {
    padding: 48px 0 80px;
}
.produit-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
}

/* ── PHOTO ── */
.produit-photo {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--beige);
    background: var(--cream-soft);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: sticky;
    top: 90px;
}
.produit-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
}
.produit-photo .no-photo {
    font-size: 8rem;
    flex-direction: column;
    display: flex;
    align-items: center;
    gap: 12px;
}
.produit-photo .no-photo small {
    font-size: 1rem;
    color: var(--text-muted);
    font-family: 'Jost', sans-serif;
}

/* ── INFOS ── */
.produit-infos { padding-top: 8px; }
.produit-cat {
    font-size: .68rem; letter-spacing: 3px;
    text-transform: uppercase; color: var(--brown);
    display: block; margin-bottom: 12px;
}
.produit-nom {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem; color: var(--brown-dark);
    line-height: 1.15; margin-bottom: 20px;
}
.produit-prix {
    font-size: 1.8rem; font-weight: 600;
    color: var(--brown); margin-bottom: 24px;
}

.gold-divider {
    width: 40px; height: 2px;
    background: var(--gold);
    margin: 24px 0;
}
.produit-desc {
    font-size: .95rem; color: var(--text-soft);
    line-height: 1.8; margin-bottom: 32px;
}

/* ── CTA ── */
.btn-rdv {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 32px; border-radius: 6px;
    background: var(--brown); color: var(--white);
    border: 1px solid var(--brown);
    font-size: .82rem; font-weight: 500; letter-spacing: 2px;
    text-transform: uppercase; font-family: 'Jost', sans-serif;
    text-decoration: none;
    transition: var(--ease); width: 100%; justify-content: center;
    margin-bottom: 12px;
}
.btn-rdv:hover { background: var(--brown-dark); border-color: var(--brown-dark); color: var(--white); }

.btn-contact {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 11px; border-radius: 6px;
    border: 1px solid var(--beige-dark); background: var(--cream-soft);
    font-size: .8rem; font-weight: 500; letter-spacing: 1.5px;
    text-transform: uppercase; font-family: 'Jost', sans-serif; color: var(--text-soft);
    text-decoration: none;
    transition: var(--ease);
}
.btn-contact:hover { border-color: var(--brown); color: var(--brown); background: rgba(125,78,45,.06); }

.info-list { list-style: none; margin-top: 28px; }
.info-list li {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 0; border-bottom: 1px solid var(--beige);
    font-size: .87rem; color: var(--text-soft);
}
.info-list li:last-child { border-bottom: none; }
.info-list .ico { font-size: 1.1rem; width: 22px; text-align: center; }

/* ── PRODUITS SIMILAIRES ── */
.similaires { padding: 64px 0; background: var(--cream-soft); }
.sim-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.sim-card {
    background: var(--white); border: 1px solid var(--beige);
    border-radius: 8px; overflow: hidden; transition: all .3s ease;
    text-decoration: none; display: block;
}
.sim-card:hover {
    border-color: var(--brown-light);
    box-shadow: 0 8px 24px rgba(125,78,45,.1);
    transform: translateY(-3px);
}
.sim-img {
    height: 160px; background: var(--cream-soft);
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem; border-bottom: 1px solid var(--beige);
}
.sim-img img { width: 100%; height: 100%; object-fit: cover; }
.sim-body { padding: 16px; }
.sim-body h4 { font-family:'Cormorant Garamond',serif; font-size:1.05rem; color:var(--brown-dark); margin-bottom:6px; }
.sim-body .sim-prix { color:var(--brown); font-weight:600; font-size:.9rem; }

@media (max-width: 860px) {
    .produit-layout { grid-template-columns: 1fr; gap: 32px; }
    .produit-photo { position: static; }
    .sim-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 540px) { .sim-grid { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block body %}

{# BREADCRUMB #}
<div class="breadcrumb">
    <div class="container">
        <a href="{{ path('app_home') }}">Accueil</a>
        <span>/</span>
        <a href="{{ path('app_boutique') }}">Boutique</a>
        <span>/</span>
        {{ produit.nom }}
    </div>
</div>

{# DÉTAIL PRODUIT #}
<div class="produit-wrap">
    <div class="container">
        <div class="produit-layout">

            {# PHOTO #}
            <div class="produit-photo">
                {% if produit.image %}
                    <img src="/uploads/produits/{{ produit.image }}" alt="{{ produit.nom }}">
                {% else %}
                    <div class="no-photo">
                        <svg width="72" height="72" fill="none" viewBox="0 0 24 24" stroke="var(--beige-dark)" stroke-width="1" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        <small>Photo bientôt disponible</small>
                    </div>
                {% endif %}
            </div>

            {# INFOS #}
            <div class="produit-infos">
                <span class="produit-cat">✦ {{ produit.categorie.nom }}</span>
                <h1 class="produit-nom">{{ produit.nom }}</h1>

                <div class="produit-prix">{{ produit.prix|number_format(0,',',' ') }} FCFA</div>

                <div class="gold-divider"></div>

                {% if produit.description %}
                    <p class="produit-desc">{{ produit.description }}</p>
                {% endif %}

                {# CTA WhatsApp #}
                {% set msg = "Bonjour BeautyAffair 👋%0AJe souhaite commander :%0A*" ~ produit.nom ~ "*%0APrix : " ~ produit.prix|number_format(0,',',' ') ~ " FCFA%0A%0AMerci de confirmer la disponibilité 🙏" %}
                <a href="https://wa.me/{{ salon_whatsapp }}?text={{ msg }}"
                   target="_blank" rel="noopener" class="btn-rdv" style="background:#25D366;border-color:#25D366;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                    Commander via WhatsApp
                </a>
                <a href="{{ path('app_rdv') }}" class="btn-contact">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    Prendre rendez-vous en salon
                </a>

                <ul class="info-list">
                    <li><span class="ico"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span> Livraison à Cotonou après confirmation WhatsApp</li>
                    <li><span class="ico"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></span> Paiement par MTN Money ou Moov Money</li>
                    <li><span class="ico"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span> Conseils personnalisés sur demande</li>
                </ul>
            </div>

        </div>
    </div>
</div>

{# PRODUITS SIMILAIRES #}
{% if similaires is not empty %}
<section class="similaires">
    <div class="container">
        <div style="text-align:center;margin-bottom:36px;">
            <span style="font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--brown);display:block;margin-bottom:10px;">✦ Dans la même catégorie</span>
            <h2 style="color:var(--brown-dark);">Vous aimerez aussi</h2>
        </div>
        <div class="sim-grid">
            {% for p in similaires %}
            <a href="{{ path('app_boutique_show', {id: p.id}) }}" class="sim-card">
                <div class="sim-img">
                    {% if p.image %}
                        <img src="/uploads/produits/{{ p.image }}" alt="{{ p.nom }}">
                    {% else %}
                        <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="var(--beige-dark)" stroke-width="1.3" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    {% endif %}
                </div>
                <div class="sim-body">
                    <h4>{{ p.nom }}</h4>
                    <div class="sim-prix">{{ p.prix|number_format(0,',',' ') }} FCFA</div>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% endblock %}
