{% extends 'base.html.twig' %}
{% block title %}Boutique · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.page-header {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 100%);
    padding: 72px 0 56px; text-align: center;
    position: relative; overflow: hidden;
}
.page-header::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% 100%,rgba(196,147,63,.15) 0%,transparent 65%); }
.page-header .container { position:relative; z-index:1; }
.page-header .eyebrow { font-size:.68rem; letter-spacing:3px; text-transform:uppercase; color:var(--beige); display:block; margin-bottom:14px; }
.page-header h1 { color:var(--cream); margin-bottom:14px; }
.page-header p  { color:var(--beige-dark); max-width:48ch; margin:0 auto; }

.section { padding: 80px 0; }
.section-alt { background: var(--cream-soft); }
.section-header { text-align: center; margin-bottom: 52px; }
.section-header .eyebrow { font-size:.68rem; letter-spacing:3px; text-transform:uppercase; color:var(--brown); display:block; margin-bottom:14px; }
.section-header h2 { color:var(--brown-dark); margin-bottom:14px; }

.product-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
.product-card {
    background: var(--white); border: 1px solid var(--beige);
    border-radius: 8px; overflow: hidden; transition: all .3s ease;
    display: flex; flex-direction: column;
}
.product-card:hover {
    border-color: var(--brown-light);
    box-shadow: 0 10px 32px rgba(125,78,45,.1);
    transform: translateY(-4px);
}
.product-img {
    height: 210px; background: var(--cream-soft);
    display: flex; align-items: center; justify-content: center;
    font-size: 4.5rem; border-bottom: 1px solid var(--beige);
    flex-shrink: 0;
}
.product-body { padding: 20px; flex: 1; }
.product-body h4 { font-family:'Cormorant Garamond',serif; font-size:1.15rem; color:var(--brown-dark); margin-bottom:8px; }
.product-body p  { font-size:.85rem; color:var(--text-soft); margin-bottom:0; line-height:1.6; }
.product-footer {
    display: flex; justify-content: space-between;
    align-items: center; gap: 10px;
    padding: 14px 20px; border-top: 1px solid var(--beige);
    flex-shrink: 0;
}
.product-price { color:var(--brown); font-weight:600; font-size:1rem; }
.stock-badge {
    font-size:.68rem; padding:2px 8px; border-radius:3px;
    background:rgba(22,163,74,.08); color:#166534;
}
.stock-badge.low  { background:rgba(234,179,8,.1); color:#854d0e; }
.stock-badge.none { background:rgba(220,38,38,.08); color:#991b1b; }

.add-cart-form { display:inline; }
.add-cart-form button {
    display:inline-flex; align-items:center; gap:6px;
    padding:7px 16px; border-radius:4px;
    background:var(--brown); color:var(--white);
    border:1px solid var(--brown); cursor:pointer;
    font-size:.75rem; font-weight:500; letter-spacing:1.5px;
    text-transform:uppercase; font-family:'Jost',sans-serif;
    transition:var(--ease); white-space:nowrap;
}
.add-cart-form button:hover { background:var(--brown-dark); border-color:var(--brown-dark); }
.add-cart-form button:disabled { opacity:.5; cursor:not-allowed; }
.add-cart-form button svg { width:14px; height:14px; }

.info-band { padding: 56px 0; }
.info-band .three-col > div { text-align:center; padding:24px; }

.fav-btn {
    width:34px; height:34px; border-radius:50%;
    border:1px solid var(--beige-dark); background:var(--cream-soft);
    cursor:pointer; display:flex; align-items:center; justify-content:center;
    flex-shrink:0; transition:transform .15s ease, border-color .2s;
}
.fav-btn:hover { border-color:var(--brown); }
.fav-btn svg { width:15px; height:15px; stroke:var(--brown-light); fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; transition:all .2s; }
.fav-btn.is-fav { border-color:var(--brown); background:rgba(125,78,45,.08); }
.fav-btn.is-fav svg { fill:var(--brown); stroke:var(--brown); }

@media (max-width: 900px) { .product-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .product-grid { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container">
        <span class="eyebrow">✦ Boutique</span>
        <h1>Boutique BeautyAffair</h1>
        <p>Perruques naturelles & synthétiques, bijoux et accessoires. Livraison à Cotonou.</p>
    </div>
</div>

{# ── PERRUQUES ── #}
<section class="section">
    <div class="container">
        <div class="section-header">
            <span class="eyebrow">✦ Perruques & Extensions</span>
            <h2>Changez de look en un instant</h2>
            <div class="gold-line"></div>
        </div>

        {% if perruques is empty %}
            <p style="text-align:center;color:var(--text-muted);padding:40px 0;">Aucun produit disponible pour le moment.</p>
        {% else %}
        <div class="product-grid">
            {% for produit in perruques %}
            {% include 'boutique/_card.html.twig' with {produit: produit, favorisIds: favorisIds, icone: '👱‍♀️'} %}
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>

{# ── BIJOUX ── #}
<section class="section section-alt">
    <div class="container">
        <div class="section-header">
            <span class="eyebrow">✦ Bijoux & Accessoires</span>
            <h2>Sublimez chaque tenue</h2>
            <div class="gold-line"></div>
        </div>

        {% if bijoux is empty %}
            <p style="text-align:center;color:var(--text-muted);padding:40px 0;">Aucun produit disponible pour le moment.</p>
        {% else %}
        <div class="product-grid">
            {% for produit in bijoux %}
            {% include 'boutique/_card.html.twig' with {produit: produit, favorisIds: favorisIds, icone: '💍'} %}
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>

{# ── INFOS LIVRAISON ── #}
<section class="info-band section">
    <div class="container">
        <div class="three-col">
            <div>
                <div style="font-size:2.5rem;margin-bottom:14px;">🚚</div>
                <h3 style="color:var(--brown-dark);margin-bottom:8px;">Livraison Cotonou</h3>
                <p>Livraison rapide sous 24–48h après confirmation de commande.</p>
            </div>
            <div style="background:var(--cream-soft);border-radius:8px;">
                <div style="font-size:2.5rem;margin-bottom:14px;">💳</div>
                <h3 style="color:var(--brown-dark);margin-bottom:8px;">Paiement sécurisé</h3>
                <p>MTN Mobile Money, Moov Money ou carte bancaire via PayDunya.</p>
            </div>
            <div>
                <div style="font-size:2.5rem;margin-bottom:14px;">↩️</div>
                <h3 style="color:var(--brown-dark);margin-bottom:8px;">Retours faciles</h3>
                <p>Produit non conforme ? Contactez-nous sous 48h.</p>
            </div>
        </div>
    </div>
</section>

{% endblock %}

{% block javascripts %}
<script>
(function () {
    var CSRF  = '{{ csrf_token('fav') }}';
    var badge = document.getElementById('fav-badge');

    document.querySelectorAll('.fav-btn').forEach(function (btn) {
        btn.addEventListener('click', async function () {
            try {
                var resp = await fetch(btn.dataset.url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: '_token=' + encodeURIComponent(CSRF),
                });
                if (!resp.ok) return;
                var data = await resp.json();

                btn.classList.toggle('is-fav', data.added);
                btn.title = data.added ? 'Retirer des favoris' : 'Ajouter aux favoris';

                btn.style.transform = 'scale(1.35)';
                setTimeout(function () { btn.style.transform = ''; }, 180);

                if (badge) {
                    badge.textContent = data.count;
                    badge.style.display = data.count > 0 ? '' : 'none';
                }
            } catch (e) {}
        });
    });
})();
</script>
{% endblock %}
