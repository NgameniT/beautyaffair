{% extends 'base.html.twig' %}
{% block title %}Contact · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.page-header {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 100%);
    padding: 72px 0 56px;
    text-align: center;
    position: relative; overflow: hidden;
}
.page-header::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 100%, rgba(196,147,63,.15) 0%, transparent 65%);
}
.page-header .container { position: relative; z-index: 1; }
.page-header .eyebrow {
    font-size: .68rem; letter-spacing: 3px;
    text-transform: uppercase; color: var(--beige);
    display: block; margin-bottom: 14px;
}
.page-header h1 { color: var(--cream); margin-bottom: 14px; }
.page-header p { color: var(--beige-dark); max-width: 48ch; margin: 0 auto; }

.section { padding: 80px 0; }
.section-alt { background: var(--cream-soft); }

.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px; align-items: start;
}

.info-block { margin-bottom: 32px; }
.info-block h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; color: var(--brown-dark);
    margin-bottom: 16px;
}
.info-item {
    display: flex; gap: 14px; align-items: flex-start;
    margin-bottom: 14px; font-size: .9rem;
}
.info-item .ico {
    width: 38px; height: 38px; flex-shrink: 0;
    background: rgba(125,78,45,.1);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
}
.info-item strong { color: var(--brown-dark); display: block; font-size: .8rem; margin-bottom: 2px; }
.info-item span { color: var(--text-soft); }

.horaire-table { width: 100%; }
.horaire-row {
    display: flex; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid var(--beige);
    font-size: .9rem;
}
.horaire-row:last-child { border-bottom: none; }
.horaire-row .day { color: var(--text-soft); }
.horaire-row .time { color: var(--brown); font-weight: 500; }

.contact-form {
    background: var(--white);
    border: 1px solid var(--beige);
    border-radius: 10px;
    padding: 36px 32px;
}
.contact-form h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; color: var(--brown-dark);
    margin-bottom: 8px;
}
.contact-form > p { color: var(--text-soft); margin-bottom: 28px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

@media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container">
        <span class="eyebrow">✦ Contact</span>
        <h1>Nous contacter</h1>
        <p>Une question ? Une demande spéciale ? Envoyez-nous un message, nous répondons sous 24h.</p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="contact-grid">

            <!-- INFOS -->
            <div>
                <div class="info-block">
                    <h3>Nos coordonnées</h3>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
                        <div>
                            <strong>Adresse</strong>
                            <span>Cotonou, Bénin</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.92 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.85 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
                        <div>
                            <strong>Téléphone</strong>
                            <a href="tel:{{ salon_whatsapp }}" style="color:var(--brown);">{{ salon_phone }}</a>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
                        <div>
                            <strong>WhatsApp</strong>
                            <a href="https://wa.me/{{ salon_whatsapp }}?text=Bonjour%20BeautyAffair%20👋%20Je%20souhaite%20avoir%20des%20informations."
                               target="_blank" rel="noopener" style="color:#25D366;font-weight:600;">
                               {{ salon_phone }}
                            </a>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/></svg></div>
                        <div>
                            <strong>Email</strong>
                            <span>contact@beautyaffair.bj</span>
                        </div>
                    </div>
                </div>

                <div class="info-block">
                    <h3>Horaires d'ouverture</h3>
                    <div class="horaire-table">
                        <div class="horaire-row">
                            <span class="day">Lundi – Vendredi</span>
                            <span class="time">08h00 – 19h00</span>
                        </div>
                        <div class="horaire-row">
                            <span class="day">Samedi</span>
                            <span class="time">08h00 – 20h00</span>
                        </div>
                        <div class="horaire-row">
                            <span class="day">Dimanche</span>
                            <span class="time">10h00 – 17h00</span>
                        </div>
                    </div>
                </div>

                <div class="info-block">
                    <h3>Réseaux sociaux</h3>
                    <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">

                        {# Instagram #}
                        <a href="https://www.instagram.com/beauty_affair_salon?igsh=MTA1Mm9nNGd3eGZlbw==" target="_blank" rel="noopener" aria-label="Instagram"
                           style="width:42px;height:42px;border-radius:50%;background:radial-gradient(circle at 30% 107%,#fdf497 0%,#fdf497 5%,#fd5949 45%,#d6249f 60%,#285AEB 90%);display:flex;align-items:center;justify-content:center;transition:opacity .2s;flex-shrink:0;"
                           onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="#fff" stroke="none"/></svg>
                        </a>

                        {# TikTok #}
                        <a href="https://www.tiktok.com/@fai_18k1?_r=1&_t=ZS-968EdkFwLht" target="_blank" rel="noopener" aria-label="TikTok"
                           style="width:42px;height:42px;border-radius:50%;background:#010101;display:flex;align-items:center;justify-content:center;transition:opacity .2s;flex-shrink:0;"
                           onmouseover="this.style.opacity='.75'" onmouseout="this.style.opacity='1'">
                            <svg width="19" height="19" viewBox="0 0 24 24" fill="#fff"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.78a4.85 4.85 0 0 1-1.01-.09z"/></svg>
                        </a>

                        {# WhatsApp #}
                        <a href="https://wa.me/{{ salon_whatsapp }}?text=Bonjour%20BeautyAffair%20👋%20Je%20souhaite%20avoir%20des%20informations."
                           target="_blank" rel="noopener" aria-label="WhatsApp"
                           style="width:42px;height:42px;border-radius:50%;background:#25D366;display:flex;align-items:center;justify-content:center;transition:opacity .2s;flex-shrink:0;"
                           onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                        </a>

                    </div>
                </div>
            </div>

            <!-- FORMULAIRE -->
            <div class="contact-form">
                <h3>Envoyer un message</h3>
                <p>Remplissez le formulaire ci-dessous et nous vous recontacterons rapidement.</p>

                {% for label, messages in app.flashes %}
                    {% for msg in messages %}
                        <div style="padding:12px 16px;border-radius:6px;margin-bottom:16px;font-size:.875rem;border:1px solid;
                            {% if label=='success' %}background:rgba(22,163,74,.08);color:#166534;border-color:rgba(22,163,74,.3);
                            {% else %}background:rgba(220,38,38,.08);color:#991b1b;border-color:rgba(220,38,38,.3);{% endif %}">
                            {{ msg }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <form method="post" action="{{ path('app_contact') }}">
                    <div class="form-row">
                        <div class="field">
                            <label for="nom">Nom</label>
                            <input type="text" id="nom" name="nom" placeholder="Votre nom" required>
                        </div>
                        <div class="field">
                            <label for="prenom">Prénom</label>
                            <input type="text" id="prenom" name="prenom" placeholder="Votre prénom">
                        </div>
                    </div>
                    <div class="field">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="votre@email.com" required>
                    </div>
                    <div class="field">
                        <label for="telephone">Téléphone (optionnel)</label>
                        <input type="tel" id="telephone" name="telephone" placeholder="+229 XX XX XX XX">
                    </div>
                    <div class="field">
                        <label for="sujet">Sujet</label>
                        <select id="sujet" name="sujet">
                            <option value="">Choisissez un sujet</option>
                            <option>Rendez-vous</option>
                            <option>Commande boutique</option>
                            <option>Renseignements tarifs</option>
                            <option>Autre</option>
                        </select>
                    </div>
                    <div class="field">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" rows="5" placeholder="Votre message..." required></textarea>
                    </div>
                    <button type="submit" class="btn" style="width:100%;">Envoyer le message</button>
                </form>
            </div>

        </div>
    </div>
</section>

{% endblock %}
