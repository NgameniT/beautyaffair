{% extends 'base.html.twig' %}
{% block title %}Contact · BeautyAffair{% endblock %}

{% block stylesheets %}
<style>
.page-header {
    background: linear-gradient(135deg, var(--brown-dark) 0%, #5C2F0E 100%);
    padding: 72px 0 56px;
    text-align: center;
    position: relative; overflow: hidden;
}
.page-header::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 100%, rgba(196,147,63,.15) 0%, transparent 65%);
}
.page-header .container { position: relative; z-index: 1; }
.page-header .eyebrow {
    font-size: .68rem; letter-spacing: 3px;
    text-transform: uppercase; color: var(--beige);
    display: block; margin-bottom: 14px;
}
.page-header h1 { color: var(--cream); margin-bottom: 14px; }
.page-header p { color: var(--beige-dark); max-width: 48ch; margin: 0 auto; }

.section { padding: 80px 0; }
.section-alt { background: var(--cream-soft); }

.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px; align-items: start;
}

.info-block { margin-bottom: 32px; }
.info-block h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; color: var(--brown-dark);
    margin-bottom: 16px;
}
.info-item {
    display: flex; gap: 14px; align-items: flex-start;
    margin-bottom: 14px; font-size: .9rem;
}
.info-item .ico {
    width: 38px; height: 38px; flex-shrink: 0;
    background: rgba(125,78,45,.1);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
}
.info-item strong { color: var(--brown-dark); display: block; font-size: .8rem; margin-bottom: 2px; }
.info-item span { color: var(--text-soft); }

.horaire-table { width: 100%; }
.horaire-row {
    display: flex; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid var(--beige);
    font-size: .9rem;
}
.horaire-row:last-child { border-bottom: none; }
.horaire-row .day { color: var(--text-soft); }
.horaire-row .time { color: var(--brown); font-weight: 500; }

.contact-form {
    background: var(--white);
    border: 1px solid var(--beige);
    border-radius: 10px;
    padding: 36px 32px;
}
.contact-form h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; color: var(--brown-dark);
    margin-bottom: 8px;
}
.contact-form > p { color: var(--text-soft); margin-bottom: 28px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

@media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container">
        <span class="eyebrow">✦ Contact</span>
        <h1>Nous contacter</h1>
        <p>Une question ? Une demande spéciale ? Envoyez-nous un message, nous répondons sous 24h.</p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="contact-grid">

            <!-- INFOS -->
            <div>
                <div class="info-block">
                    <h3>Nos coordonnées</h3>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
                        <div>
                            <strong>Adresse</strong>
                            <span>Cotonou, Bénin</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.92 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.85 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
                        <div>
                            <strong>Téléphone</strong>
                            <a href="tel:{{ salon_whatsapp }}" style="color:var(--brown);">{{ salon_phone }}</a>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
                        <div>
                            <strong>WhatsApp</strong>
                            <a href="https://wa.me/{{ salon_whatsapp }}?text=Bonjour%20BeautyAffair%20👋%20Je%20souhaite%20avoir%20des%20informations."
                               target="_blank" rel="noopener" style="color:#25D366;font-weight:600;">
                               {{ salon_phone }}
                            </a>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="ico"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/></svg></div>
                        <div>
                            <strong>Email</strong>
                            <span>contact@beautyaffair.bj</span>
                        </div>
                    </div>
                </div>

                <div class="info-block">
                    <h3>Horaires d'ouverture</h3>
                    <div class="horaire-table">
                        <div class="horaire-row">
                            <span class="day">Lundi – Vendredi</span>
                            <span class="time">08h00 – 19h00</span>
                        </div>
                        <div class="horaire-row">
                            <span class="day">Samedi</span>
                            <span class="time">08h00 – 20h00</span>
                        </div>
                        <div class="horaire-row">
                            <span class="day">Dimanche</span>
                            <span class="time">10h00 – 17h00</span>
                        </div>
                    </div>
                </div>

                <div class="info-block">
                    <h3>Réseaux sociaux</h3>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;">
                        <a href="#" class="btn-outline btn-xs">Facebook</a>
                        <a href="#" class="btn-outline btn-xs">Instagram</a>
                        <a href="#" class="btn-outline btn-xs">TikTok</a>
                        <a href="#" class="btn-outline btn-xs">WhatsApp</a>
                    </div>
                </div>
            </div>

            <!-- FORMULAIRE -->
            <div class="contact-form">
                <h3>Envoyer un message</h3>
                <p>Remplissez le formulaire ci-dessous et nous vous recontacterons rapidement.</p>

                {% for label, messages in app.flashes %}
                    {% for msg in messages %}
                        <div style="padding:12px 16px;border-radius:6px;margin-bottom:16px;font-size:.875rem;border:1px solid;
                            {% if label=='success' %}background:rgba(22,163,74,.08);color:#166534;border-color:rgba(22,163,74,.3);
                            {% else %}background:rgba(220,38,38,.08);color:#991b1b;border-color:rgba(220,38,38,.3);{% endif %}">
                            {{ msg }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <form method="post" action="{{ path('app_contact') }}">
                    <div class="form-row">
                        <div class="field">
                            <label for="nom">Nom</label>
                            <input type="text" id="nom" name="nom" placeholder="Votre nom" required>
                        </div>
                        <div class="field">
                            <label for="prenom">Prénom</label>
                            <input type="text" id="prenom" name="prenom" placeholder="Votre prénom">
                        </div>
                    </div>
                    <div class="field">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="votre@email.com" required>
                    </div>
                    <div class="field">
                        <label for="telephone">Téléphone (optionnel)</label>
                        <input type="tel" id="telephone" name="telephone" placeholder="+229 XX XX XX XX">
                    </div>
                    <div class="field">
                        <label for="sujet">Sujet</label>
                        <select id="sujet" name="sujet">
                            <option value="">Choisissez un sujet</option>
                            <option>Rendez-vous</option>
                            <option>Commande boutique</option>
                            <option>Renseignements tarifs</option>
                            <option>Autre</option>
                        </select>
                    </div>
                    <div class="field">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" rows="5" placeholder="Votre message..." required></textarea>
                    </div>
                    <button type="submit" class="btn" style="width:100%;">Envoyer le message</button>
                </form>
            </div>

        </div>
    </div>
</section>

{% endblock %}
