{% extends 'base.html.twig' %}

{% block title %}Mon espace | BiblioConnect{% endblock %}

{% block body %}

<!-- En-tête profil -->
<div style="display:flex;align-items:center;justify-content:space-between;gap:20px;margin-bottom:28px;flex-wrap:wrap;">
    <div>
        <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--g400);margin-bottom:6px;">Mon espace</span>
        <h1 style="margin-bottom:4px;">{{ ((user.prenom ~ ' ' ~ user.nom)|trim) ?: user.userIdentifier }}</h1>
    </div>
    <a class="btn-outline btn-xs" href="{{ path('app_catalogue') }}" style="text-decoration:none;">Parcourir le catalogue</a>
</div>

<!-- Statistiques -->
<div class="stats-row" style="margin-bottom:28px;">
    <div class="stat-card">
        <strong>{{ activeLoans|length }}</strong>
        <p>Emprunts actifs</p>
    </div>
    <div class="stat-card">
        <strong>{{ favorites|length }}</strong>
        <p>Livres favoris</p>
    </div>
</div>

<!-- Emprunts en cours -->
<div class="card card-body" style="margin-bottom:24px;">
    <div class="flex-between" style="margin-bottom:18px;">
        <div>
            <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--g400);margin-bottom:4px;">Emprunts</span>
            <h2 style="font-size:1.15rem;">Livres en cours</h2>
        </div>
        <a class="btn-ghost btn-xs" href="{{ path('app_catalogue') }}" style="text-decoration:none;">+ Emprunter</a>
    </div>

    {% if activeLoans is empty %}
        <div class="empty-state" style="padding:28px 0 8px;">
            <h3>Aucun emprunt en cours</h3>
            <p>Parcourez le catalogue pour réserver votre prochain livre.</p>
        </div>
    {% else %}
        <div class="item-list">
            {% for loan in activeLoans %}
                <div class="item-row">
                    <div style="flex:1;min-width:0;">
                        <span class="item-title">{{ loan.book.title }}</span>
                        <span class="item-meta">
                            {{ loan.book.author }} · Retour attendu le <strong>{{ loan.dueAt|date('d/m/Y') }}</strong>
                            {% if loan.scheduledFor %}
                                · planifié pour le {{ loan.scheduledFor|date('d/m/Y') }}
                            {% endif %}
                        </span>
                    </div>
                    <form method="post" action="{{ path('app_dashboard_return_loan', {id: loan.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('return-loan-' ~ loan.id) }}">
                        <button class="btn-outline btn-xs" type="submit">Déclarer le retour</button>
                    </form>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<!-- Favoris -->
<div class="card card-body" style="margin-bottom:24px;">
    <div class="flex-between" style="margin-bottom:18px;">
        <div>
            <span style="display:block;font-size:.72rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--g400);margin-bottom:4px;">Favoris</span>
            <h2 style="font-size:1.15rem;">Vos livres favoris</h2>
        </div>
    </div>

    {% if favorites is empty %}
        <div class="empty-state" style="padding:28px 0 8px;">
            <h3>Aucun favori</h3>
            <p>Ajoutez des livres à vos favoris depuis le catalogue.</p>
        </div>
    {% else %}
        <div class="book-grid">
            {% for favorite in favorites %}
                <a href="{{ path('app_catalogue_show', {id: favorite.book.id}) }}" style="text-decoration:none;">
                    <div class="card book-card" style="overflow:hidden;">
                        <div class="book-cover theme-{{ favorite.book.coverTheme }}" style="min-height:100px;padding:14px 16px;">
                            <div class="cover-chips"><span class="cover-chip">{{ favorite.book.category }}</span></div>
                            <div><h3 style="font-size:.85rem;">{{ favorite.book.title }}</h3></div>
                        </div>
                        <div style="padding:12px 14px;">
                            <p style="font-size:.78rem;color:var(--g500);">{{ favorite.book.author }}</p>
                            <p style="font-size:.72rem;color:var(--g400);margin-top:2px;">Ajouté le {{ favorite.createdAt|date('d/m/Y') }}</p>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>

{% endblock %}
